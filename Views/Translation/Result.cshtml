@{
    ViewData["Title"] = "Translation Results - Film Website Admin";
}

<style>
    /* AI Translation Styles - Blue & Dark Theme */
    body {
        background: #0f172a !important;
        color: #ffffff !important;
    }

    .ai-translation-container {
        background: #0f172a;
        min-height: 100vh;
        padding: 20px 0;
        color: #ffffff;
    }

    /* Main Translation Card */
    .translation-card {
        background: #1e293b;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        border: 1px solid #334155;
        margin-bottom: 30px;
        overflow: hidden;
    }

        .translation-card .card-header {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            color: white;
            padding: 20px 24px;
            border-bottom: none;
        }

        .translation-card .card-title {
            margin: 0;
            font-weight: 700;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
        }

        .translation-card .card-body {
            padding: 30px;
            background: #1e293b;
        }

    /* Success header override */
    .card-header.bg-success {
        background: linear-gradient(135deg, #06d6a0 0%, #059669 100%) !important;
    }

    /* Form Controls */
    .form-label {
        color: #ffffff;
        font-weight: 600;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        font-size: 0.95rem;
    }

    .form-text {
        color: #94a3b8;
        font-size: 0.8rem;
        margin-top: 6px;
    }

    /* Language Selects */
    .language-select, .form-select {
        background: #334155 !important;
        border: 1px solid #475569 !important;
        color: #ffffff !important;
        border-radius: 8px;
        padding: 12px 16px;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        width: 100%;
    }

        .language-select:focus, .form-select:focus {
            border-color: #0ea5e9 !important;
            box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1) !important;
            background: #334155 !important;
            color: #ffffff !important;
            outline: none;
        }

        .language-select option, .form-select option {
            background: #334155 !important;
            color: #ffffff !important;
        }

    /* Buttons */
    .btn-process {
        background: linear-gradient(135deg, #0ea5e9, #0284c7);
        border: none;
        color: white;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 700;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-process:hover {
            background: linear-gradient(135deg, #0284c7, #0369a1);
            transform: translateY(-1px);
            color: white;
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.3);
            text-decoration: none;
        }

        .btn-process:active {
            transform: translateY(0);
        }

        .btn-process:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }

    /* Success button variant */
    .btn-success {
        background: linear-gradient(135deg, #06d6a0, #059669) !important;
        border: none !important;
        color: white !important;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 700;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-success:hover {
            background: linear-gradient(135deg, #059669, #047857) !important;
            transform: translateY(-1px);
            color: white !important;
            box-shadow: 0 4px 12px rgba(6, 214, 160, 0.3);
            text-decoration: none;
        }

    /* Primary button override */
    .btn-primary {
        background: linear-gradient(135deg, #0ea5e9, #0284c7) !important;
        border: none !important;
        color: white !important;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 700;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-primary:hover {
            background: linear-gradient(135deg, #0284c7, #0369a1) !important;
            transform: translateY(-1px);
            color: white !important;
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.3);
            text-decoration: none;
        }

    /* Outline buttons */
    .btn-outline-primary {
        border-color: #0ea5e9 !important;
        color: #0ea5e9 !important;
        background: transparent !important;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-outline-primary:hover {
            background: #0ea5e9 !important;
            border-color: #0ea5e9 !important;
            color: white !important;
            text-decoration: none;
        }

    .btn-outline-secondary {
        border-color: #475569 !important;
        color: #94a3b8 !important;
        background: transparent !important;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-outline-secondary:hover {
            background: #475569 !important;
            border-color: #475569 !important;
            color: white !important;
            text-decoration: none;
        }

    .btn-outline-warning {
        border-color: #fbbf24 !important;
        color: #fbbf24 !important;
        background: transparent !important;
        padding: 12px 24px;
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-outline-warning:hover {
            background: #fbbf24 !important;
            border-color: #fbbf24 !important;
            color: #1e293b !important;
            text-decoration: none;
        }

    /* Alert Styling */
    .alert {
        border: none !important;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }

    .alert-danger {
        background: rgba(239, 68, 68, 0.1) !important;
        border-left: 4px solid #ef4444 !important;
        color: #ef4444 !important;
    }

    .alert-success {
        background: rgba(6, 214, 160, 0.1) !important;
        border-left: 4px solid #06d6a0 !important;
        color: #06d6a0 !important;
    }

    .alert-warning {
        background: rgba(251, 191, 36, 0.1) !important;
        border-left: 4px solid #fbbf24 !important;
        color: #fbbf24 !important;
    }

    .alert-info {
        background: rgba(14, 165, 233, 0.1) !important;
        border-left: 4px solid #0ea5e9 !important;
        color: #0ea5e9 !important;
    }

    /* Progress and Loading */
    .spinner-border {
        color: #0ea5e9 !important;
    }

    .progress {
        background: #475569 !important;
        height: 8px;
        border-radius: 4px;
    }

    .progress-bar {
        background: linear-gradient(90deg, #0ea5e9, #0284c7) !important;
    }

    .progress-bar-striped {
        background-image: linear-gradient(45deg, rgba(255,255,255,.15) 25%, transparent 25%, transparent 50%, rgba(255,255,255,.15) 50%, rgba(255,255,255,.15) 75%, transparent 75%, transparent) !important;
    }

    .progress-bar-animated {
        animation: progress-bar-stripes 1s linear infinite !important;
    }

    /* Accuracy Check Styles */
    .accuracy-check-section {
        animation: slideIn 0.5s ease-in-out;
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .metric-card {
        padding: 1rem;
        border: 1px solid #475569;
        border-radius: 8px;
        background: #334155;
        margin-bottom: 1rem;
    }

    .metric-value {
        font-size: 2rem;
        font-weight: bold;
        color: #0ea5e9;
    }

    .metric-label {
        font-size: 0.875rem;
        color: #94a3b8;
        margin-top: 0.25rem;
    }

    .risk-badge {
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: bold;
        font-size: 1rem;
    }

    .risk-safe {
        background: #065f46;
        color: #06d6a0;
    }

    .risk-potentially-sensitive {
        background: #92400e;
        color: #fbbf24;
    }

    .risk-inappropriate {
        background: #991b1b;
        color: #ef4444;
    }

    .similarity-high {
        color: #06d6a0;
    }

    .similarity-medium {
        color: #fbbf24;
    }

    .similarity-low {
        color: #ef4444;
    }

    .accuracy-high {
        color: #06d6a0;
    }

    .accuracy-medium {
        color: #fbbf24;
    }

    .accuracy-low {
        color: #ef4444;
    }

    .sensitive-highlight {
        background-color: #fbbf24 !important;
        border: 2px solid #f59e0b;
        border-radius: 4px;
        padding: 2px 4px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.7;
        }

        100% {
            opacity: 1;
        }
    }

    /* Table Styling */
    .table {
        background: #1e293b !important;
        color: white !important;
    }

        .table th {
            background: #334155 !important;
            color: white !important;
            border: none !important;
        }

        .table td {
            vertical-align: middle;
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            background: #1e293b !important;
            color: white !important;
            border-color: #334155 !important;
        }

    .table-striped > tbody > tr:nth-of-type(odd) > td {
        background: #334155 !important;
        color: white !important;
    }

    .table-hover tbody tr:hover td {
        background: #475569 !important;
        color: white !important;
    }

    .table-warning td {
        background: rgba(251, 191, 36, 0.8) !important;
        color: #1e293b !important;
        font-weight: 500 !important;
    }

    .table-warning:hover td {
        background: rgba(251, 191, 36, 0.9) !important;
        color: #0f172a !important;
    }

    /* Fix text contrast for sensitive content */
    .sensitive-highlight td {
        background-color: #fbbf24 !important;
        color: #1e293b !important;
        border: 2px solid #f59e0b;
        border-radius: 4px;
        padding: 2px 4px;
        animation: pulse 2s infinite;
        font-weight: 600 !important;
    }

    .table-responsive {
        border-radius: 8px;
        overflow: hidden;
    }

    .btn-detail {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
        background: #0ea5e9;
        border-color: #0ea5e9;
        color: white;
        border-radius: 4px;
        border: 1px solid #0ea5e9;
        cursor: pointer;
    }

        .btn-detail:hover {
            background: #0284c7;
            border-color: #0284c7;
            color: white;
        }

    /* Badge styling */
    .badge {
        padding: 0.5em 0.75em;
        font-size: 0.75em;
        font-weight: 700;
        border-radius: 0.375rem;
    }

    .bg-success {
        background-color: #059669 !important;
    }

    .bg-warning {
        background-color: #f59e0b !important;
        color: #1e293b !important;
    }

    .bg-danger {
        background-color: #dc2626 !important;
    }

    .bg-secondary {
        background-color: #6b7280 !important;
    }

    /* Modal Styling */
    .modal-content {
        background: #1e293b !important;
        color: white !important;
        border: 1px solid #334155;
    }

    .modal-header {
        background: #334155 !important;
        border-bottom: 1px solid #475569 !important;
    }

    .modal-footer {
        background: #334155 !important;
        border-top: 1px solid #475569 !important;
    }

    .btn-close-white {
        filter: invert(1) grayscale(100%) brightness(200%);
    }

    .modal-body .border {
        border-color: #475569 !important;
    }

    /* Text Colors */
    .text-success {
        color: #06d6a0 !important;
    }

    .text-warning {
        color: #fbbf24 !important;
    }

    .text-muted {
        color: #64748b !important;
    }

    /* Bootstrap overrides */
    .container {
        max-width: 100%;
    }

    .row {
        margin-left: 0;
        margin-right: 0;
    }

    .col-md-4, .col-md-6, .col-lg-10, .col-12 {
        padding-left: 15px;
        padding-right: 15px;
    }

    /* Card overrides */
    .card {
        background: #1e293b !important;
        border: 1px solid #334155 !important;
        border-radius: 12px;
        color: white !important;
    }

    .card-header {
        background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%) !important;
        border-bottom: none !important;
        color: white !important;
        padding: 20px 24px;
    }

    .card-body {
        background: #1e293b !important;
        color: white !important;
        padding: 24px;
    }

    .card-title {
        margin: 0;
        font-weight: 700;
        font-size: 1.25rem;
        display: flex;
        align-items: center;
    }

    .h-100 {
        height: 100% !important;
    }

    /* Override any remaining Bootstrap defaults */
    ol, ul, p {
        color: #ffffff !important;
    }

    /* Loading Animation */
    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }

        100% {
            transform: rotate(360deg);
        }
    }

    .fa-spin {
        animation: spin 1s infinite linear;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .ai-translation-container {
            padding: 10px 0;
        }

        .translation-card .card-body {
            padding: 20px;
        }

        .btn-process {
            width: 100%;
            min-width: auto;
        }
    }

    @@media (max-width: 576px) {
        .translation-card .card-title {
            font-size: 1.3rem;
        }
    }
</style>

<div class="ai-translation-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="translation-card">
                    <div class="card-header" style="background: linear-gradient(135deg, #06d6a0 0%, #059669 100%);">
                        <h3 class="card-title">
                            <i class="fas fa-check-circle me-2"></i>
                            Translation Complete!
                        </h3>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-success" role="alert">
                            <i class="fas fa-thumbs-up me-2"></i>
                            Your video "<strong>@ViewBag.OriginalFileName</strong>" has been successfully processed.
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="translation-card h-100">
                                    <div class="card-header" style="background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);">
                                        <h5 class="card-title">
                                            <i class="fas fa-file-alt me-2"></i>
                                            Original Subtitles
                                        </h5>
                                    </div>
                                    <div class="card-body text-center">
                                        <p style="color: #94a3b8;">
                                            Original transcribed subtitles from your video's audio track.
                                        </p>
                                        <a href="@ViewBag.OriginalSrtPath" class="btn-process" download style="min-width: auto; padding: 12px 24px;">
                                            <i class="fas fa-download me-2"></i>
                                            Download Original SRT
                                        </a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="translation-card h-100">
                                    <div class="card-header" style="background: linear-gradient(135deg, #06d6a0 0%, #059669 100%);">
                                        <h5 class="card-title">
                                            <i class="fas fa-language me-2"></i>
                                            Translated Subtitles (@ViewBag.TargetLanguage)
                                        </h5>
                                    </div>
                                    <div class="card-body text-center">
                                        <p style="color: #94a3b8;">
                                            Subtitles translated to @ViewBag.TargetLanguage using AI translation.
                                        </p>
                                        <a href="@ViewBag.TranslatedSrtPath" class="btn-success" download style="min-width: auto; padding: 12px 24px;">
                                            <i class="fas fa-download me-2"></i>
                                            Download @ViewBag.TargetLanguage SRT
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ==================== ACCURACY CHECK SECTION ==================== -->
                        <div id="accuracyCheckSection" class="accuracy-check-section mt-4">
                            <div class="translation-card" style="border-color: #0ea5e9;">
                                <div class="card-header" style="background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);">
                                    <h5 class="card-title">
                                        <i class="fas fa-check-circle me-2"></i>
                                        Translation Accuracy Check
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <!-- Check Accuracy Button -->
                                    <div id="accuracyCheckControls" class="mb-3">
                                        <div class="row">
                                            <div class="col-md-8">
                                                <label for="targetCountry" class="form-label">Target Country (for cultural context):</label>
                                                <select id="targetCountry" class="form-select">
                                                    <option value="">Auto-detect</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4 d-flex align-items-end">
                                                <button id="checkAccuracyBtn" class="btn-process w-100" style="min-width: auto;">
                                                    <i class="fas fa-search me-2"></i>
                                                    Check Accuracy
                                                </button>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Loading State -->
                                    <div id="accuracyCheckLoading" class="text-center py-4" style="display: none;">
                                        <div class="spinner-border" role="status">
                                            <span class="visually-hidden">Loading...</span>
                                        </div>
                                        <div class="mt-3">
                                            <h6>Running 3-Layer Accuracy Analysis...</h6>
                                            <div id="loadingProgress">
                                                <div class="progress mb-2">
                                                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar"></div>
                                                </div>
                                                <div id="currentStep" class="text-muted">Initializing...</div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Results Display -->
                                    <div id="accuracyResults" style="display: none;">
                                        <!-- Overall Summary -->
                                        <div class="accuracy-summary mb-4">
                                            <div class="row text-center">
                                                <div class="col-md-3">
                                                    <div class="metric-card">
                                                        <div class="metric-value" id="overallSimilarity">--</div>
                                                        <div class="metric-label">Semantic Similarity</div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="metric-card">
                                                        <div class="metric-value" id="overallAccuracy">--</div>
                                                        <div class="metric-label">Accuracy Score</div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="metric-card">
                                                        <div class="risk-badge" id="culturalRisk">--</div>
                                                        <div class="metric-label">Cultural Risk</div>
                                                    </div>
                                                </div>
                                                <div class="col-md-3">
                                                    <div class="metric-card">
                                                        <div class="metric-value" id="sensitiveCount">--</div>
                                                        <div class="metric-label">Sensitive Items</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Overall Feedback -->
                                        <div class="alert alert-info">
                                            <h6><i class="fas fa-info-circle me-2"></i>Overall Assessment</h6>
                                            <div id="overallFeedback">--</div>
                                            <div id="culturalComment" class="mt-2">--</div>
                                        </div>

                                        <!-- Detailed Results Table -->
                                        <div class="table-responsive">
                                            <table class="table table-striped table-hover">
                                                <thead>
                                                    <tr>
                                                        <th>#</th>
                                                        <th>Original Text</th>
                                                        <th>Translated Text</th>
                                                        <th>Similarity</th>
                                                        <th>Accuracy</th>
                                                        <th>Risk Level</th>
                                                        <th>Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="accuracyTableBody">
                                                    <!-- Results will be populated here -->
                                                </tbody>
                                            </table>
                                        </div>

                                        <!-- Export Options -->
                                        <div class="mt-3">
                                            <button id="exportReportBtn" class="btn-outline-secondary">
                                                <i class="fas fa-download me-2"></i>
                                                Download Report
                                            </button>
                                            <button id="highlightSensitiveBtn" class="btn-outline-warning ms-2">
                                                <i class="fas fa-highlight me-2"></i>
                                                Highlight Sensitive Content
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- ==================== END ACCURACY CHECK SECTION ==================== -->

                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="translation-card">
                                    <div class="card-header">
                                        <h5 class="card-title">
                                            <i class="fas fa-info-circle me-2"></i>
                                            Usage Instructions
                                        </h5>
                                    </div>
                                    <div class="card-body">
                                        <ol>
                                            <li><strong>Download the SRT files</strong> using the buttons above</li>
                                            <li><strong>Open your video player</strong> (VLC, Media Player, etc.)</li>
                                            <li><strong>Load your video file</strong> and the corresponding SRT subtitle file</li>
                                            <li><strong>Enable subtitles</strong> in your video player settings</li>
                                        </ol>
                                        <p style="color: #94a3b8;" class="mb-0">
                                            <i class="fas fa-lightbulb me-1"></i>
                                            <strong>Tip:</strong> Most video players automatically detect SRT files if they have the same name as your video file.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mt-3">
                            <div class="col-12 text-center">
                                <a href="@Url.Action("Upload", "Translation")" class="btn-outline-primary">
                                    <i class="fas fa-plus me-2"></i>
                                    Process Another Video
                                </a>
                                <a href="@Url.Action("Index", "Admin")" class="btn-outline-secondary ms-2">
                                    <i class="fas fa-arrow-left me-2"></i>
                                    Back to Admin Dashboard
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detail Modal for Sentence Analysis -->
<div class="modal fade" id="sentenceDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Sentence Analysis Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <h6>Original Text</h6>
                        <div class="border p-2" style="background: #334155;" id="modalOriginalText">--</div>
                    </div>
                    <div class="col-md-6">
                        <h6>Translated Text</h6>
                        <div class="border p-2" style="background: #334155;" id="modalTranslatedText">--</div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <h6>Semantic Similarity</h6>
                        <div class="h4" id="modalSimilarity">--</div>
                    </div>
                    <div class="col-md-4">
                        <h6>Accuracy Score</h6>
                        <div class="h4" id="modalAccuracy">--</div>
                    </div>
                    <div class="col-md-4">
                        <h6>Cultural Risk</h6>
                        <div id="modalRisk">--</div>
                    </div>
                </div>

                <div class="mb-3">
                    <h6>Accuracy Feedback</h6>
                    <div class="alert alert-info" id="modalFeedback">--</div>
                </div>

                <div class="mb-3" id="modalCulturalSection" style="display: none;">
                    <h6>Cultural Analysis</h6>
                    <div class="alert alert-warning">
                        <div id="modalCulturalComment">--</div>
                        <div id="modalCulturalSuggestion" class="mt-2 fw-bold">--</div>
                    </div>
                </div>

                <div id="modalSensitiveWords" style="display: none;">
                    <h6>Sensitive Words Detected</h6>
                    <div id="sensitiveWordsList">--</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Anti-forgery token for AJAX requests -->
@Html.AntiForgeryToken()

<script>
    // Global variables to store translation result data
    let translationResult = null;
    let accuracyCheckInProgress = false;

    // Initialize accuracy check functionality when page loads
    document.addEventListener('DOMContentLoaded', function() {
        // Extract file names from ViewBag data
        const originalSrtPath = '@ViewBag.OriginalSrtPath';
        const translatedSrtPath = '@ViewBag.TranslatedSrtPath';
        const sourceLanguage = '@ViewBag.SourceLanguage';
        const targetLanguage = '@ViewBag.TargetLanguage';

        // Extract just the filename from the full path
        const originalFileName = originalSrtPath.split('fileName=')[1];
        const translatedFileName = translatedSrtPath.split('fileName=')[1];

        if (originalFileName && translatedFileName) {
            initializeAccuracyCheck(originalFileName, translatedFileName, sourceLanguage, targetLanguage);
        }
    });

    // Initialize accuracy check functionality
    function initializeAccuracyCheck(originalFile, translatedFile, sourceLanguage, targetLanguage) {
        translationResult = {
            originalFile: originalFile,
            translatedFile: translatedFile,
            sourceLanguage: sourceLanguage,
            targetLanguage: targetLanguage
        };

        // Load target countries
        loadTargetCountries();

        // Bind event handlers
        document.getElementById('checkAccuracyBtn').addEventListener('click', startAccuracyCheck);
        document.getElementById('exportReportBtn').addEventListener('click', exportAccuracyReport);
        document.getElementById('highlightSensitiveBtn').addEventListener('click', highlightSensitiveContent);
    }

    // Load available target countries
    async function loadTargetCountries() {
        try {
            const response = await fetch('/Translation/GetTargetCountries');
            const result = await response.json();

            if (result.success) {
                const select = document.getElementById('targetCountry');
                select.innerHTML = '<option value="">Auto-detect</option>';

                result.countries.forEach(country => {
                    const option = document.createElement('option');
                    option.value = country;
                    option.textContent = country;
                    select.appendChild(option);
                });
            }
        } catch (error) {
            console.error('Error loading target countries:', error);
        }
    }

    // Start accuracy check process
    async function startAccuracyCheck() {
        if (accuracyCheckInProgress) return;

        accuracyCheckInProgress = true;

        // Hide controls and results, show loading
        document.getElementById('accuracyCheckControls').style.display = 'none';
        document.getElementById('accuracyResults').style.display = 'none';
        document.getElementById('accuracyCheckLoading').style.display = 'block';

        // Start progress animation
        let progress = 0;
        const progressBar = document.getElementById('progressBar');
        const currentStep = document.getElementById('currentStep');

        const steps = [
            'Initializing accuracy check...',
            'Reading subtitle files...',
            'Running semantic similarity analysis...',
            'Checking translation accuracy with GPT...',
            'Analyzing cultural sensitivity...',
            'Generating final report...'
        ];

        let stepIndex = 0;
        const progressInterval = setInterval(() => {
            progress += Math.random() * 15 + 5; // Random progress increment
            if (progress > 95) progress = 95;

            progressBar.style.width = progress + '%';

            if (stepIndex < steps.length - 1 && progress > (stepIndex + 1) * 15) {
                stepIndex++;
                currentStep.textContent = steps[stepIndex];
            }
        }, 800);

        try {
            const targetCountry = document.getElementById('targetCountry').value;

            // Get CSRF token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            const formData = new FormData();
            formData.append('originalFile', translationResult.originalFile);
            formData.append('translatedFile', translationResult.translatedFile);
            formData.append('sourceLanguage', translationResult.sourceLanguage);
            formData.append('targetLanguage', translationResult.targetLanguage);
            formData.append('targetCountry', targetCountry);
            formData.append('__RequestVerificationToken', token);

            const response = await fetch('/Translation/CheckAccuracy', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            // Complete progress
            clearInterval(progressInterval);
            progressBar.style.width = '100%';
            currentStep.textContent = 'Analysis complete!';

            setTimeout(() => {
                document.getElementById('accuracyCheckLoading').style.display = 'none';

                if (result.success) {
                    displayAccuracyResults(result.data);
                } else {
                    showError('Accuracy check failed: ' + result.message);
                    document.getElementById('accuracyCheckControls').style.display = 'block';
                }

                accuracyCheckInProgress = false;
            }, 1000);

        } catch (error) {
            clearInterval(progressInterval);
            console.error('Error during accuracy check:', error);
            showError('Error during accuracy check: ' + error.message);

            document.getElementById('accuracyCheckLoading').style.display = 'none';
            document.getElementById('accuracyCheckControls').style.display = 'block';
            accuracyCheckInProgress = false;
        }
    }

    // Display accuracy check results
    function displayAccuracyResults(data) {
        // Update overall metrics
        document.getElementById('overallSimilarity').textContent = (data.semanticSimilarity * 100).toFixed(1) + '%';
        document.getElementById('overallAccuracy').textContent = data.accuracyScore + '%';
        document.getElementById('sensitiveCount').textContent = data.sentenceResults.filter(s => s.isSensitive).length;

        // Update cultural risk badge
        const riskBadge = document.getElementById('culturalRisk');
        riskBadge.textContent = data.culturalRisk;
        riskBadge.className = 'risk-badge risk-' + data.culturalRisk.toLowerCase().replace(' ', '-');

        // Update feedback
        document.getElementById('overallFeedback').textContent = data.accuracyFeedback;
        document.getElementById('culturalComment').textContent = data.culturalComment;

        // Populate results table
        const tableBody = document.getElementById('accuracyTableBody');
        tableBody.innerHTML = '';

        data.sentenceResults.forEach((sentence, index) => {
            const row = document.createElement('tr');
            if (sentence.isSensitive) {
                row.classList.add('table-warning');
            }

            const similarityClass = sentence.semanticSimilarity >= 0.8 ? 'similarity-high' :
                                   sentence.semanticSimilarity >= 0.6 ? 'similarity-medium' : 'similarity-low';

            const accuracyClass = sentence.accuracyScore >= 80 ? 'accuracy-high' :
                                 sentence.accuracyScore >= 60 ? 'accuracy-medium' : 'accuracy-low';

            row.innerHTML = `
                <td>${sentence.index}</td>
                <td title="${escapeHtml(sentence.originalText)}">${truncateText(sentence.originalText, 50)}</td>
                <td title="${escapeHtml(sentence.translatedText)}">${truncateText(sentence.translatedText, 50)}</td>
                <td class="${similarityClass}">${(sentence.semanticSimilarity * 100).toFixed(1)}%</td>
                <td class="${accuracyClass}">${sentence.accuracyScore}%</td>
                <td>
                    <span class="badge" style="background-color: ${getRiskBgColor(sentence.culturalRisk)}; color: ${getRiskTextColor(sentence.culturalRisk)};">
                        ${sentence.culturalRisk}
                    </span>
                </td>
                <td>
                    <button class="btn-detail" onclick="showSentenceDetail(${index})">
                        <i class="fas fa-eye"></i> Details
                    </button>
                </td>
            `;

            tableBody.appendChild(row);
        });

        // Show results
        document.getElementById('accuracyResults').style.display = 'block';

        // Store results for later use
        window.currentAccuracyResults = data;
    }

    // Show detailed sentence analysis
    function showSentenceDetail(index) {
        const sentence = window.currentAccuracyResults.sentenceResults[index];

        document.getElementById('modalOriginalText').textContent = sentence.originalText;
        document.getElementById('modalTranslatedText').textContent = sentence.translatedText;
        document.getElementById('modalSimilarity').textContent = (sentence.semanticSimilarity * 100).toFixed(1) + '%';
        document.getElementById('modalAccuracy').textContent = sentence.accuracyScore + '%';
        document.getElementById('modalRisk').innerHTML = `<span class="badge" style="background-color: ${getRiskBgColor(sentence.culturalRisk)}; color: ${getRiskTextColor(sentence.culturalRisk)};">${sentence.culturalRisk}</span>`;
        document.getElementById('modalFeedback').textContent = sentence.feedback;

        // Cultural analysis section
        if (sentence.culturalComment || sentence.culturalSuggestion) {
            document.getElementById('modalCulturalSection').style.display = 'block';
            document.getElementById('modalCulturalComment').textContent = sentence.culturalComment;
            document.getElementById('modalCulturalSuggestion').textContent = sentence.culturalSuggestion;
        } else {
            document.getElementById('modalCulturalSection').style.display = 'none';
        }

        // Sensitive words
        if (sentence.sensitiveWords && sentence.sensitiveWords.length > 0) {
            document.getElementById('modalSensitiveWords').style.display = 'block';
            const wordsList = sentence.sensitiveWords.map(word =>
                `<span class="badge" style="background: #fbbf24; color: #1e293b; margin-right: 4px;">${escapeHtml(word)}</span>`
            ).join('');
            document.getElementById('sensitiveWordsList').innerHTML = wordsList;
        } else {
            document.getElementById('modalSensitiveWords').style.display = 'none';
        }

        // Show modal
        new bootstrap.Modal(document.getElementById('sentenceDetailModal')).show();
    }

    // Export accuracy report
    async function exportAccuracyReport() {
        try {
            const url = `/Translation/DownloadAccuracyReport?originalFile=${encodeURIComponent(translationResult.originalFile)}&translatedFile=${encodeURIComponent(translationResult.translatedFile)}`;
            window.open(url, '_blank');
        } catch (error) {
            console.error('Error exporting report:', error);
            showError('Error exporting report: ' + error.message);
        }
    }

    // Highlight sensitive content in the results
    function highlightSensitiveContent() {
        const tableBody = document.getElementById('accuracyTableBody');
        const sensitiveRows = tableBody.querySelectorAll('tr.table-warning');

        sensitiveRows.forEach(row => {
            row.classList.add('sensitive-highlight');
            setTimeout(() => {
                row.classList.remove('sensitive-highlight');
            }, 3000);
        });

        if (sensitiveRows.length === 0) {
            showInfo('No sensitive content detected in this translation.');
        }
    }

    // Utility functions
    function getRiskBgColor(risk) {
        switch (risk.toLowerCase()) {
            case 'safe': return '#065f46';
            case 'potentially sensitive': return '#92400e';
            case 'inappropriate': return '#991b1b';
            default: return '#475569';
        }
    }

    function getRiskTextColor(risk) {
        switch (risk.toLowerCase()) {
            case 'safe': return '#06d6a0';
            case 'potentially sensitive': return '#fbbf24';
            case 'inappropriate': return '#ef4444';
            default: return '#94a3b8';
        }
    }

    function truncateText(text, maxLength) {
        if (text.length <= maxLength) return escapeHtml(text);
        return escapeHtml(text.substring(0, maxLength)) + '...';
    }

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function showError(message) {
        alert('Error: ' + message);
    }

    function showInfo(message) {
        alert('Info: ' + message);
    }
</script>