@{
    ViewData["Title"] = "Translation Results - Film Website Admin";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h3 class="mb-0">
                    <i class="fas fa-check-circle me-2"></i>
                    Translation Complete!
                </h3>
            </div>
            <div class="card-body">
                <div class="alert alert-success" role="alert">
                    <i class="fas fa-thumbs-up me-2"></i>
                    Your video "<strong>@ViewBag.OriginalFileName</strong>" has been successfully processed.
                </div>

                <!-- *** Session Persistence Information *** -->
                @if (ViewBag.ProcessedDate != null)
                {
                    <div class="alert alert-info" role="alert">
                        <div class="d-flex align-items-center">
                            <i class="fas fa-bookmark me-2"></i>
                            <div>
                                <strong>Your Results Are Saved!</strong><br>
                                <small>
                                    Processed on @ViewBag.ProcessedDate.ToString("MMM dd, yyyy 'at' HH:mm").
                                    You can bookmark this page or return to it anytime within the next 2 hours to access your translation results and accuracy checks.
                                </small>
                            </div>
                        </div>
                    </div>
                }

                <div class="row">
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="fas fa-file-alt text-primary me-2"></i>
                                    Original Subtitles
                                </h5>
                            </div>
                            <div class="card-body text-center">
                                <p class="card-text">
                                    Original transcribed subtitles from your video's audio track.
                                </p>
                                <a href="@ViewBag.OriginalSrtPath" class="btn btn-primary" download>
                                    <i class="fas fa-download me-2"></i>
                                    Download Original SRT
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="fas fa-language text-success me-2"></i>
                                    Translated Subtitles (@ViewBag.TargetLanguage)
                                </h5>
                            </div>
                            <div class="card-body text-center">
                                <p class="card-text">
                                    Subtitles translated to @ViewBag.TargetLanguage using AI translation.
                                </p>
                                <a href="@ViewBag.TranslatedSrtPath" class="btn btn-success" download>
                                    <i class="fas fa-download me-2"></i>
                                    Download @ViewBag.TargetLanguage SRT
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ==================== ACCURACY CHECK SECTION ==================== -->
                <div id="accuracyCheckSection" class="accuracy-check-section mt-4">
                    <div class="card border-info">
                        <div class="card-header bg-info text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-check-circle me-2"></i>
                                Translation Accuracy Check
                            </h5>
                        </div>
                        <div class="card-body">
                            <!-- CSRF Token for AJAX requests -->
                            @Html.AntiForgeryToken()

                            <!-- Check Accuracy Button -->
                            <div id="accuracyCheckControls" class="mb-3">
                                <div class="row">
                                    <div class="col-md-8">
                                        <label for="targetCountry" class="form-label">Target Country (for cultural context):</label>
                                        <select id="targetCountry" class="form-select">
                                            <option value="">Auto-detect</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4 d-flex align-items-end">
                                        <button id="checkAccuracyBtn" class="btn btn-info btn-lg w-100">
                                            <i class="fas fa-search me-2"></i>
                                            Check Accuracy
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!-- Loading State -->
                            <div id="accuracyCheckLoading" class="text-center py-4" style="display: none;">
                                <div class="spinner-border text-info" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <div class="mt-3">
                                    <h6>Running 3-Layer Accuracy Analysis...</h6>
                                    <div id="loadingProgress">
                                        <div class="progress mb-2">
                                            <div id="progressBar" class="progress-bar bg-info progress-bar-striped progress-bar-animated"
                                                 role="progressbar" style="width: 0%"></div>
                                        </div>
                                        <div id="currentStep" class="text-muted">Initializing...</div>
                                    </div>
                                </div>
                            </div>

                            <!-- Results Display -->
                            <div id="accuracyResults" style="display: none;">
                                <!-- Overall Summary -->
                                <div class="accuracy-summary mb-4">
                                    <div class="row text-center">
                                        <div class="col-md-3">
                                            <div class="metric-card">
                                                <div class="metric-value" id="overallSimilarity">--</div>
                                                <div class="metric-label">Semantic Similarity</div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="metric-card">
                                                <div class="metric-value" id="overallAccuracy">--</div>
                                                <div class="metric-label">Accuracy Score</div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="metric-card">
                                                <div class="metric-value" id="culturalRisk">--</div>
                                                <div class="metric-label">Cultural Risk</div>
                                            </div>
                                        </div>
                                        <div class="col-md-3">
                                            <div class="metric-card">
                                                <div class="metric-value" id="sensitiveCount">--</div>
                                                <div class="metric-label">Sensitive Items</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Feedback Section -->
                                <div class="feedback-section mb-4">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h6>Overall Assessment</h6>
                                            <div class="alert alert-light" id="overallFeedback">--</div>
                                        </div>
                                        <div class="col-md-6">
                                            <h6>Cultural Sensitivity</h6>
                                            <div class="alert alert-light" id="culturalComment">--</div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Detailed Results Table -->
                                <div class="table-responsive">
                                    <table class="table table-striped">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>Original Text</th>
                                                <th>Translated Text</th>
                                                <th>Similarity</th>
                                                <th>Accuracy</th>
                                                <th>Risk Level</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody id="accuracyTableBody">
                                            <!-- Results will be populated here -->
                                        </tbody>
                                    </table>
                                </div>

                                <!-- Export Options -->
                                <div class="mt-3">
                                    <button id="exportReportBtn" class="btn btn-outline-secondary">
                                        <i class="fas fa-download me-2"></i>
                                        Download Report
                                    </button>
                                    <button id="highlightSensitiveBtn" class="btn btn-outline-warning ms-2">
                                        <i class="fas fa-highlight me-2"></i>
                                        Highlight Sensitive Content
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- ==================== END ACCURACY CHECK SECTION ==================== -->

                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="fas fa-info-circle text-info me-2"></i>
                                    Usage Instructions
                                </h5>
                            </div>
                            <div class="card-body">
                                <ol>
                                    <li><strong>Download the SRT files</strong> using the buttons above</li>
                                    <li><strong>Open your video player</strong> (VLC, Media Player, etc.)</li>
                                    <li><strong>Load your video file</strong> and the corresponding SRT subtitle file</li>
                                    <li><strong>Enable subtitles</strong> in your video player settings</li>
                                </ol>
                                <p class="text-muted mb-0">
                                    <i class="fas fa-lightbulb me-1"></i>
                                    <strong>Tip:</strong> Most video players automatically detect SRT files if they have the same name as your video file.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12 text-center">
                        <a href="@Url.Action("Upload", "Translation")" class="btn btn-outline-primary">
                            <i class="fas fa-plus me-2"></i>
                            Process Another Video
                        </a>
                        <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary ms-2">
                            <i class="fas fa-arrow-left me-2"></i>
                            Back to Admin Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detail Modal for Sentence Analysis -->
<div class="modal fade" id="sentenceDetailModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Sentence Analysis Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <h6>Original Text</h6>
                        <div class="border p-2 bg-light" id="modalOriginalText">--</div>
                    </div>
                    <div class="col-md-6">
                        <h6>Translated Text</h6>
                        <div class="border p-2 bg-light" id="modalTranslatedText">--</div>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <h6>Semantic Similarity</h6>
                        <div class="h4" id="modalSimilarity">--</div>
                    </div>
                    <div class="col-md-4">
                        <h6>Accuracy Score</h6>
                        <div class="h4" id="modalAccuracy">--</div>
                    </div>
                    <div class="col-md-4">
                        <h6>Risk Level</h6>
                        <div class="h4" id="modalRisk">--</div>
                    </div>
                </div>

                <div class="mb-3">
                    <h6>Feedback</h6>
                    <div class="alert alert-info" id="modalFeedback">--</div>
                </div>

                <div class="mb-3">
                    <h6>Cultural Comment</h6>
                    <div class="alert alert-warning" id="modalCultural">--</div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .accuracy-check-section {
        animation: fadeIn 0.5s ease-in;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .metric-card {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    .metric-value {
        font-size: 2rem;
        font-weight: bold;
        color: #0d6efd;
    }

    .metric-label {
        color: #6c757d;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .risk-badge {
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .risk-safe {
        background: #d1edff;
        color: #0c63e4;
    }

    .risk-potentially-sensitive {
        background: #fff3cd;
        color: #856404;
    }

    .risk-inappropriate {
        background: #f8d7da;
        color: #721c24;
    }

    .similarity-high {
        color: #28a745;
    }

    .similarity-medium {
        color: #ffc107;
    }

    .similarity-low {
        color: #dc3545;
    }

    .accuracy-high {
        color: #28a745;
    }

    .accuracy-medium {
        color: #ffc107;
    }

    .accuracy-low {
        color: #dc3545;
    }

    .sensitive-highlight {
        background-color: #ffeb3b !important;
        border: 2px solid #ff9800;
        border-radius: 4px;
        padding: 2px 4px;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.7;
        }

        100% {
            opacity: 1;
        }
    }

    .table th {
        background-color: #343a40;
        color: white;
        border: none;
    }

    .table td {
        vertical-align: middle;
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .btn-detail {
        padding: 0.25rem 0.5rem;
        font-size: 0.75rem;
    }

    #loadingProgress .progress {
        height: 8px;
    }

    .modal-lg {
        max-width: 900px;
    }
</style>

<script>
    // Global variables to store translation result data
    let translationResult = null;
    let accuracyCheckInProgress = false;
    let currentAccuracyData = null; // Store accuracy results for detail view

    // Initialize accuracy check functionality when page loads
    document.addEventListener('DOMContentLoaded', function() {
        // Extract file names from ViewBag data
        const originalSrtPath = '@ViewBag.OriginalSrtPath';
        const translatedSrtPath = '@ViewBag.TranslatedSrtPath';
        const sourceLanguage = '@ViewBag.SourceLanguage';
        const targetLanguage = '@ViewBag.TargetLanguage';

        // Extract just the filename from the full path
        if (originalSrtPath && translatedSrtPath) {
            const originalFileName = originalSrtPath.split('fileName=')[1];
            const translatedFileName = translatedSrtPath.split('fileName=')[1];

            if (originalFileName && translatedFileName) {
                initializeAccuracyCheck(originalFileName, translatedFileName, sourceLanguage, targetLanguage);
            }
        }
    });

    // Initialize accuracy check functionality
    function initializeAccuracyCheck(originalFile, translatedFile, sourceLanguage, targetLanguage) {
        translationResult = {
            originalFile: originalFile,
            translatedFile: translatedFile,
            sourceLanguage: sourceLanguage,
            targetLanguage: targetLanguage
        };

        // Load target countries
        loadTargetCountries();

        // Bind event handlers
        const checkBtn = document.getElementById('checkAccuracyBtn');
        const exportBtn = document.getElementById('exportReportBtn');
        const highlightBtn = document.getElementById('highlightSensitiveBtn');

        if (checkBtn) checkBtn.addEventListener('click', startAccuracyCheck);
        if (exportBtn) exportBtn.addEventListener('click', exportAccuracyReport);
        if (highlightBtn) highlightBtn.addEventListener('click', highlightSensitiveContent);
    }

    // Load available target countries
    async function loadTargetCountries() {
        try {
            const response = await fetch('/Translation/GetTargetCountries');
            const result = await response.json();

            if (result.success) {
                const select = document.getElementById('targetCountry');
                if (select) {
                    select.innerHTML = '<option value="">Auto-detect</option>';

                    result.countries.forEach(country => {
                        const option = document.createElement('option');
                        option.value = country;
                        option.textContent = country;
                        select.appendChild(option);
                    });
                }
            }
        } catch (error) {
            console.error('Error loading target countries:', error);
        }
    }

    // Start accuracy check process
    async function startAccuracyCheck() {
        if (accuracyCheckInProgress) return;

        accuracyCheckInProgress = true;

        // Hide controls and results, show loading
        const controls = document.getElementById('accuracyCheckControls');
        const results = document.getElementById('accuracyResults');
        const loading = document.getElementById('accuracyCheckLoading');

        if (controls) controls.style.display = 'none';
        if (results) results.style.display = 'none';
        if (loading) loading.style.display = 'block';

        // Start progress animation
        let progress = 0;
        const progressBar = document.getElementById('progressBar');
        const currentStep = document.getElementById('currentStep');

        const steps = [
            'Initializing accuracy check...',
            'Reading subtitle files...',
            'Running semantic similarity analysis...',
            'Checking translation accuracy with GPT...',
            'Analyzing cultural sensitivity...',
            'Generating final report...'
        ];

        let stepIndex = 0;
        const progressInterval = setInterval(() => {
            progress += Math.random() * 15 + 5; // Random progress increment
            if (progress > 95) progress = 95;

            if (progressBar) progressBar.style.width = progress + '%';

            if (stepIndex < steps.length - 1 && progress > (stepIndex + 1) * 15) {
                stepIndex++;
                if (currentStep) currentStep.textContent = steps[stepIndex];
            }
        }, 800);

        try {
            const targetCountry = document.getElementById('targetCountry')?.value || '';

            // Get CSRF token
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            const formData = new FormData();
            formData.append('originalFile', translationResult.originalFile);
            formData.append('translatedFile', translationResult.translatedFile);
            formData.append('sourceLanguage', translationResult.sourceLanguage);
            formData.append('targetLanguage', translationResult.targetLanguage);
            formData.append('targetCountry', targetCountry);
            if (token) formData.append('__RequestVerificationToken', token);

            const response = await fetch('/Translation/CheckAccuracy', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            // Complete progress
            clearInterval(progressInterval);
            if (progressBar) progressBar.style.width = '100%';
            if (currentStep) currentStep.textContent = 'Analysis complete!';

            setTimeout(() => {
                if (loading) loading.style.display = 'none';

                if (result.success) {
                    displayAccuracyResults(result.data);
                    showSuccess('Accuracy check completed successfully! Review the detailed analysis below.');
                } else {
                    showError('Accuracy check failed: ' + result.message);
                    if (controls) controls.style.display = 'block';
                }

                accuracyCheckInProgress = false;
            }, 1000);

        } catch (error) {
            clearInterval(progressInterval);
            console.error('Error during accuracy check:', error);
            showError('Error during accuracy check: ' + error.message);

            if (loading) loading.style.display = 'none';
            if (controls) controls.style.display = 'block';
            accuracyCheckInProgress = false;
        }
    }

    // Display accuracy check results
    function displayAccuracyResults(data) {
        // Store data globally for detail view
        currentAccuracyData = data;

        // Update overall metrics
        const similarityEl = document.getElementById('overallSimilarity');
        const accuracyEl = document.getElementById('overallAccuracy');
        const sensitiveEl = document.getElementById('sensitiveCount');
        const riskEl = document.getElementById('culturalRisk');

        if (similarityEl) similarityEl.textContent = (data.semanticSimilarity * 100).toFixed(1) + '%';
        if (accuracyEl) accuracyEl.textContent = data.accuracyScore + '%';
        if (sensitiveEl) sensitiveEl.textContent = data.sentenceResults.filter(s => s.isSensitive).length;

        // Update cultural risk badge
        if (riskEl) {
            riskEl.textContent = data.culturalRisk;
            riskEl.className = 'risk-badge risk-' + data.culturalRisk.toLowerCase().replace(' ', '-');
        }

        // Update feedback
        const feedbackEl = document.getElementById('overallFeedback');
        const commentEl = document.getElementById('culturalComment');
        if (feedbackEl) feedbackEl.textContent = data.accuracyFeedback;
        if (commentEl) commentEl.textContent = data.culturalComment;

        // Populate results table
        const tableBody = document.getElementById('accuracyTableBody');
        if (tableBody) {
            tableBody.innerHTML = '';

            data.sentenceResults.forEach((sentence, index) => {
                const row = document.createElement('tr');
                if (sentence.isSensitive) {
                    row.classList.add('table-warning');
                }

                const similarityClass = sentence.semanticSimilarity >= 0.8 ? 'similarity-high' :
                                       sentence.semanticSimilarity >= 0.6 ? 'similarity-medium' : 'similarity-low';

                const accuracyClass = sentence.accuracyScore >= 80 ? 'accuracy-high' :
                                     sentence.accuracyScore >= 60 ? 'accuracy-medium' : 'accuracy-low';

                row.innerHTML = `
                    <td>${sentence.index}</td>
                    <td title="${sentence.originalText}">${sentence.originalText}</td>
                    <td title="${sentence.translatedText}">${sentence.translatedText}</td>
                    <td class="${similarityClass}">${(sentence.semanticSimilarity * 100).toFixed(1)}%</td>
                    <td class="${accuracyClass}">${sentence.accuracyScore}%</td>
                    <td><span class="risk-badge risk-${sentence.culturalRisk.toLowerCase().replace(' ', '-')}">${sentence.culturalRisk}</span></td>
                    <td>
                        <button class="btn btn-outline-info btn-detail" onclick="showSentenceDetail(${index})">
                            <i class="fas fa-eye"></i> Details
                        </button>
                    </td>
                `;

                tableBody.appendChild(row);
            });
        }

        // Show results
        const results = document.getElementById('accuracyResults');
        if (results) results.style.display = 'block';
    }

    // Show sentence detail modal
    function showSentenceDetail(index) {
        if (!currentAccuracyData || !currentAccuracyData.sentenceResults[index]) {
            console.error('No data available for sentence index:', index);
            return;
        }

        const sentence = currentAccuracyData.sentenceResults[index];

        // Populate modal with sentence data
        const modalOriginalText = document.getElementById('modalOriginalText');
        const modalTranslatedText = document.getElementById('modalTranslatedText');
        const modalSimilarity = document.getElementById('modalSimilarity');
        const modalAccuracy = document.getElementById('modalAccuracy');
        const modalRisk = document.getElementById('modalRisk');
        const modalFeedback = document.getElementById('modalFeedback');
        const modalCultural = document.getElementById('modalCultural');

        if (modalOriginalText) modalOriginalText.textContent = sentence.originalText || '--';
        if (modalTranslatedText) modalTranslatedText.textContent = sentence.translatedText || '--';
        if (modalSimilarity) {
            modalSimilarity.textContent = (sentence.semanticSimilarity * 100).toFixed(1) + '%';
            modalSimilarity.className = 'h4 ' + (sentence.semanticSimilarity >= 0.8 ? 'similarity-high' :
                                                 sentence.semanticSimilarity >= 0.6 ? 'similarity-medium' : 'similarity-low');
        }
        if (modalAccuracy) {
            modalAccuracy.textContent = sentence.accuracyScore + '%';
            modalAccuracy.className = 'h4 ' + (sentence.accuracyScore >= 80 ? 'accuracy-high' :
                                               sentence.accuracyScore >= 60 ? 'accuracy-medium' : 'accuracy-low');
        }
        if (modalRisk) {
            modalRisk.textContent = sentence.culturalRisk || 'Safe';
            modalRisk.className = 'h4 risk-badge risk-' + (sentence.culturalRisk || 'safe').toLowerCase().replace(' ', '-');
        }
        if (modalFeedback) modalFeedback.textContent = sentence.feedback || 'No feedback available';
        if (modalCultural) modalCultural.textContent = sentence.culturalComment || 'No cultural concerns detected';

        // Show the modal using Bootstrap 5 modal API
        const modal = document.getElementById('sentenceDetailModal');
        if (modal) {
            const bootstrapModal = new bootstrap.Modal(modal);
            bootstrapModal.show();
        }
    }

    // Export accuracy report
    function exportAccuracyReport() {
        if (!translationResult) {
            showError('No translation data available for export.');
            return;
        }

        // Show loading state on export button
        const exportBtn = document.getElementById('exportReportBtn');
        if (exportBtn) {
            const originalText = exportBtn.innerHTML;
            exportBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Generating...';
            exportBtn.disabled = true;

            // Reset button after delay
            setTimeout(() => {
                exportBtn.innerHTML = originalText;
                exportBtn.disabled = false;
            }, 2000);
        }

        const url = `/Translation/DownloadAccuracyReport?originalFile=${encodeURIComponent(translationResult.originalFile)}&translatedFile=${encodeURIComponent(translationResult.translatedFile)}`;

        // Create a temporary link to trigger download
        const link = document.createElement('a');
        link.href = url;
        link.download = `accuracy_report_${new Date().toISOString().slice(0,10)}.json`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }

    // Highlight sensitive content
    function highlightSensitiveContent() {
        if (!currentAccuracyData) return;

        const rows = document.querySelectorAll('#accuracyTableBody tr.table-warning');
        if (rows.length === 0) {
            showError('No sensitive content found to highlight.');
            return;
        }

        rows.forEach(row => {
            row.classList.add('sensitive-highlight');
            setTimeout(() => {
                row.classList.remove('sensitive-highlight');
            }, 3000);
        });

        // Show notification
        const alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-warning alert-dismissible fade show mt-2';
        alertDiv.innerHTML = `
            <i class="fas fa-exclamation-triangle me-2"></i>
            Highlighted ${rows.length} potentially sensitive sentence(s) for review.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;

        const results = document.getElementById('accuracyResults');
        if (results) {
            results.insertBefore(alertDiv, results.firstChild);
            // Auto-remove after 5 seconds
            setTimeout(() => {
                if (alertDiv.parentNode) {
                    alertDiv.remove();
                }
            }, 5000);
        }
    }

    // Error display helper
    function showError(message) {
        // Remove any existing error alerts first
        const existingAlerts = document.querySelectorAll('.alert-danger');
        existingAlerts.forEach(alert => alert.remove());

        const errorDiv = document.createElement('div');
        errorDiv.className = 'alert alert-danger alert-dismissible fade show';
        errorDiv.innerHTML = `
            <i class="fas fa-exclamation-circle me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;

        const section = document.getElementById('accuracyCheckSection');
        if (section) {
            const cardBody = section.querySelector('.card-body');
            cardBody.insertBefore(errorDiv, cardBody.firstChild);

            // Auto-remove after 8 seconds if not manually dismissed
            setTimeout(() => {
                if (errorDiv.parentNode) {
                    errorDiv.remove();
                }
            }, 8000);
        }
    }

    // Success notification helper
    function showSuccess(message) {
        const successDiv = document.createElement('div');
        successDiv.className = 'alert alert-success alert-dismissible fade show';
        successDiv.innerHTML = `
            <i class="fas fa-check-circle me-2"></i>
            ${message}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;

        const section = document.getElementById('accuracyCheckSection');
        if (section) {
            const cardBody = section.querySelector('.card-body');
            cardBody.insertBefore(successDiv, cardBody.firstChild);

            // Auto-remove after 5 seconds
            setTimeout(() => {
                if (successDiv.parentNode) {
                    successDiv.remove();
                }
            }, 5000);
        }
    }
</script>