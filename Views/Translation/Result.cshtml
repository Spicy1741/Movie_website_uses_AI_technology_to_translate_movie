@{
    ViewData["Title"] = "Translation Results - Film Website Admin";
}

<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h3 class="mb-0">
                    <i class="fas fa-check-circle me-2"></i>
                    Translation Complete!
                </h3>
            </div>
            <div class="card-body">
                <div class="alert alert-success" role="alert">
                    <i class="fas fa-thumbs-up me-2"></i>
                    Your video "<strong>@ViewBag.OriginalFileName</strong>" has been successfully processed.
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="fas fa-file-alt text-primary me-2"></i>
                                    Original Subtitles
                                </h5>
                            </div>
                            <div class="card-body text-center">
                                <p class="card-text">
                                    Original transcribed subtitles from your video's audio track.
                                </p>
                                <a href="@ViewBag.OriginalSrtPath" class="btn btn-primary" download>
                                    <i class="fas fa-download me-2"></i>
                                    Download Original SRT
                                </a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card h-100">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="fas fa-language text-success me-2"></i>
                                    Translated Subtitles (@ViewBag.TargetLanguage)
                                </h5>
                            </div>
                            <div class="card-body text-center">
                                <p class="card-text">
                                    Subtitles translated to @ViewBag.TargetLanguage using AI translation.
                                </p>
                                <a href="@ViewBag.TranslatedSrtPath" class="btn btn-success" download>
                                    <i class="fas fa-download me-2"></i>
                                    Download @ViewBag.TargetLanguage SRT
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0">
                                    <i class="fas fa-info-circle text-info me-2"></i>
                                    Usage Instructions
                                </h5>
                            </div>
                            <div class="card-body">
                                <ol>
                                    <li><strong>Download the SRT files</strong> using the buttons above</li>
                                    <li><strong>Open your video player</strong> (VLC, Media Player, etc.)</li>
                                    <li><strong>Load your video file</strong> and the corresponding SRT subtitle file</li>
                                    <li><strong>Enable subtitles</strong> in your video player settings</li>
                                </ol>
                                <p class="text-muted mb-0">
                                    <i class="fas fa-lightbulb me-1"></i>
                                    <strong>Tip:</strong> Most video players automatically detect SRT files if they have the same name as your video file.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12 text-center">
                        <a href="@Url.Action("Upload", "Translation")" class="btn btn-outline-primary">
                            <i class="fas fa-plus me-2"></i>
                            Process Another Video
                        </a>
                        <a href="@Url.Action("Index", "Admin")" class="btn btn-outline-secondary ms-2">
                            <i class="fas fa-arrow-left me-2"></i>
                            Back to Admin Dashboard
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>