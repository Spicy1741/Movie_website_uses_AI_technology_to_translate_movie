@model Film_website.Models.Movie
@{
    ViewData["Title"] = Model.Title;
    var comments = ViewBag.Comments as List<Film_website.Models.Comment> ?? new List<Film_website.Models.Comment>();
    var commentCount = ViewBag.CommentCount ?? 0;
    var isFavorite = ViewBag.IsFavorite as bool? ?? false;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Film Website</title>
    <meta name="movie-id" content="@Model.Id" />
    @Html.AntiForgeryToken()

    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Bungee&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="~/css/Detail.css" rel="stylesheet" />
</head>

<body>
    <div class="movie-details-container">
        <!-- Header with back button -->
        <div class="details-header">
            <button class="back-btn" onclick="history.back()">
                <i class="fas fa-arrow-left"></i>
                Back
            </button>
            <h1>@Model.Title</h1>
        </div>
        <!-- Video Section -->
        <section class="video-section">
            <div class="video-container">
                <video id="moviePlayer" controls preload="metadata" data-subtitle-path="@Model.SubtitlePath">
                    @if (!string.IsNullOrEmpty(Model.FilePath))
                    {
                        <source src="@Model.FilePath" type="video/mp4">
                    }
                    @if (!string.IsNullOrEmpty(Model.SubtitlePath))
                    {
                        <track src="@Model.SubtitlePath" kind="subtitles" srclang="en" label="English" id="subtitleTrack">
                    }
                    Your browser does not support the video tag.
                </video>

                @if (string.IsNullOrEmpty(Model.FilePath))
                {
                    <div class="no-video-message">
                        <i class="fas fa-film fa-4x"></i>
                        <h3>🎬 COMING SOON 🎬</h3>
                        <p>This EPIC adventure will be available soon!</p>
                    </div>
                }
            </div>
        </section>

            <!-- NEW: Favorite Button Section -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="favorite-section">
                    <button id="favoriteBtn" class="favorite-btn @(isFavorite ? "favorited" : "")" data-movie-id="@Model.Id">
                        <i class="@(isFavorite ? "fas" : "far") fa-heart"></i>
                        <span class="favorite-text">@(isFavorite ? "Remove from Favorites" : "Add to Favorites")</span>
                    </button>
                </div>
            }

            <div class="movie-metadata">
                <div class="metadata-grid">
                    <div class="metadata-item">
                        <div class="metadata-label">Genre:</div>
                        <div class="metadata-value">
                            <span class="genre-tag">@Model.Genre</span>
                        </div>
                    </div>

                    <div class="metadata-item">
                        <div class="metadata-label">Release Year:</div>
                        <div class="metadata-value">@Model.ReleaseYear</div>
                    </div>

                    <div class="metadata-item">
                        <div class="metadata-label">Added:</div>
                        <div class="metadata-value">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                    </div>

                    <div class="metadata-item">
                        <div class="metadata-label">Subtitles:</div>
                        <div class="metadata-value">
                            @if (!string.IsNullOrEmpty(Model.SubtitlePath))
                            {
                                <span class="subtitle-available">
                                    <i class="fas fa-check"></i> Available
                                </span>
                            }
                            else
                            {
                                <span class="subtitle-unavailable">
                                    <i class="fas fa-times"></i> Not Available
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

        </section>

        <!-- Comments Section -->
        <section class="comments-section-details" data-movie-id="@Model.Id">
            <div class="comments-container">
                <h3>💬  REVIEWS 💬 <span class="comment-count">(@commentCount)</span></h3>

                @if (User.Identity.IsAuthenticated)
                {
                    <!-- Comment Form -->
                    <div class="comment-form">
                        <div class="comment-input-container">
                            <div class="user-avatar">
                                @{
                                    var userInitials = "U";
                                    var userService = Context.RequestServices.GetService(typeof(Film_website.Services.UserService)) as Film_website.Services.UserService;
                                    if (userService != null && User.Identity.Name != null)
                                    {
                                        var currentUser = await userService.GetUserByEmailOrUserNameAsync(User.Identity.Name);
                                        if (currentUser != null)
                                        {
                                            userInitials = "";
                                            if (!string.IsNullOrEmpty(currentUser.FirstName))
                                                userInitials += currentUser.FirstName[0].ToString().ToUpper();
                                            if (!string.IsNullOrEmpty(currentUser.LastName))
                                                userInitials += currentUser.LastName[0].ToString().ToUpper();
                                            if (string.IsNullOrEmpty(userInitials))
                                                userInitials = "U";
                                        }
                                    }
                                }
                                @userInitials
                            </div>
                            <textarea placeholder="Share your thoughts about this movie..."
                                  id="newComment"
                                  class="comment-textarea"
                                  rows="3"
                                  maxlength="1000"></textarea>
                        </div>
                        <div class="comment-actions">
                            <button class="action-btn secondary" onclick="cancelComment()">❌ CANCEL</button>
                            <button class="action-btn primary" onclick="addComment()">💥 POST REVIEW</button>
                        </div>
                        <div class="comment-help-text">
                            <small>Share your thoughts! Maximum 1000 characters.</small>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Login Prompt -->
                    <div class="login-prompt">
                        <p>🦸 <a href="@Url.Action("Login", "Account")">Login</a> or <a href="@Url.Action("Register", "Account")">Register</a> to share your EPIC thoughts! 🦸</p>
                    </div>
                }

                <!-- Comments List -->
                <div class="comments-list" id="commentsList">
                    @if (comments.Any())
                    {
                        @foreach (var comment in comments)
                        {
                            var userCommentInitials = "U";
                            if (!string.IsNullOrEmpty(comment.User.FirstName))
                                userCommentInitials = comment.User.FirstName[0].ToString().ToUpper();
                            if (!string.IsNullOrEmpty(comment.User.LastName))
                                userCommentInitials += comment.User.LastName[0].ToString().ToUpper();
                            if (userCommentInitials == "U" && !string.IsNullOrEmpty(comment.User.LastName))
                                userCommentInitials = comment.User.LastName[0].ToString().ToUpper();

                            var timeAgo = GetTimeAgo(comment.CreatedAt);
                            var editedText = comment.IsEdited ? " (edited)" : "";
                            var canEdit = User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == comment.UserId;
                            var canDelete = canEdit || User.IsInRole("Admin");

                            <div class="comment-item" data-comment-id="@comment.Id">
                                <div class="comment-header">
                                    <div class="comment-avatar">@userCommentInitials</div>
                                    <div class="comment-info">
                                        <div class="comment-author">@comment.User.DisplayUserName</div>
                                        <div class="comment-time">@timeAgo@editedText</div>
                                    </div>
                                    @if (canEdit || canDelete)
                                    {
                                        <div class="comment-options">
                                            <button class="comment-option-btn" onclick="toggleCommentOptions(@comment.Id)">⋮</button>
                                            <div class="comment-options-menu" id="options-@comment.Id" style="display: none;">
                                                @if (canEdit)
                                                {
                                                    <button onclick="editComment(@comment.Id)">Edit</button>
                                                }
                                                @if (canDelete)
                                                {
                                                    <button onclick="deleteComment(@comment.Id)" class="delete-option">Delete</button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="comment-content" id="content-@comment.Id">
                                    @comment.Content
                                </div>
                                <div class="comment-actions-inline">
                                    <button class="comment-action-btn" onclick="likeComment(@comment.Id)" id="like-btn-@comment.Id">
                                        👍 <span id="like-count-@comment.Id">@comment.LikeCount</span>
                                    </button>
                                    <button class="comment-action-btn" onclick="replyComment(@comment.Id)">↩ Reply</button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="no-comments-message">
                            <p>🎬 Be the first to share your thoughts about this movie! 🎬</p>
                        </div>
                    }
                </div>

                <!-- Load More Comments -->
                <div class="load-more-container">
                    <button class="action-btn secondary load-more-btn" onclick="loadMoreComments()" style="display: @(comments.Count >= 10 ? "block" : "none")">⚡ LOAD MORE HERO REVIEWS ⚡</button>
                </div>
            </div>
        </section>
    </div>

    <!-- Scripts -->
    <script src="~/js/movie-comments.js"></script>
<script>
    // Helper function for time ago calculation
    @{
        string GetTimeAgo(DateTime date)
        {
            var timeSpan = DateTime.UtcNow - date;

            if (timeSpan.TotalDays > 365)
                return $"{(int)(timeSpan.TotalDays / 365)} year{((int)(timeSpan.TotalDays / 365) > 1 ? "s" : "")} ago";
            if (timeSpan.TotalDays > 30)
                return $"{(int)(timeSpan.TotalDays / 30)} month{((int)(timeSpan.TotalDays / 30) > 1 ? "s" : "")} ago";
            if (timeSpan.TotalDays > 1)
                return $"{(int)timeSpan.TotalDays} day{((int)timeSpan.TotalDays > 1 ? "s" : "")} ago";
            if (timeSpan.TotalHours > 1)
                return $"{(int)timeSpan.TotalHours} hour{((int)timeSpan.TotalHours > 1 ? "s" : "")} ago";
            if (timeSpan.TotalMinutes > 1)
                return $"{(int)timeSpan.TotalMinutes} minute{((int)timeSpan.TotalMinutes > 1 ? "s" : "")} ago";

            return "just now";
        }
    }

    // Existing movie player functions
    function playMovie() {
        const video = document.getElementById('moviePlayer');
        if (video) {
            video.play();
        }
    }

    function toggleSubtitles() {
        const video = document.getElementById('moviePlayer');
        if (video && video.textTracks.length > 0) {
            const track = video.textTracks[0];
            track.mode = track.mode === 'showing' ? 'hidden' : 'showing';
        }
    }
               // Video Player Functions
            let video = document.getElementById('moviePlayer');
            let isPlaying = false;
            let controlsTimeout;

            function playMovie() {
                if (video) {
                    video.play();
                    updatePlayButton();
                }
            }

            function togglePlay() {
                if (video) {
                    if (video.paused) {
                        video.play();
                    } else {
                        video.pause();
                    }
                    updatePlayButton();
                }
            }

            function updatePlayButton() {
                const playBtn = document.getElementById('playBtn');
                if (playBtn) {
                    if (video.paused) {
                        playBtn.innerHTML = '<i class="fas fa-play"></i>';
                        isPlaying = false;
                    } else {
                        playBtn.innerHTML = '<i class="fas fa-pause"></i>';
                        isPlaying = true;
                    }
                }
            }

            function skipBackward() {
                if (video) {
                    video.currentTime = Math.max(0, video.currentTime - 10);
                }
            }

            function skipForward() {
                if (video) {
                    video.currentTime = Math.min(video.duration, video.currentTime + 10);
                }
            }

            function toggleMute() {
                if (video) {
                    video.muted = !video.muted;
                    updateVolumeButton();
                }
            }

            function updateVolumeButton() {
                const volumeBtn = document.getElementById('volumeBtn');
                if (volumeBtn) {
                    if (video.muted || video.volume === 0) {
                        volumeBtn.innerHTML = '<i class="fas fa-volume-mute"></i>';
                    } else if (video.volume < 0.5) {
                        volumeBtn.innerHTML = '<i class="fas fa-volume-down"></i>';
                    } else {
                        volumeBtn.innerHTML = '<i class="fas fa-volume-up"></i>';
                    }
                }
            }

            function toggleSubtitles() {
                if (video && video.textTracks.length > 0) {
                    const track = video.textTracks[0];
                    track.mode = track.mode === 'showing' ? 'hidden' : 'showing';

                    const subtitleToggle = document.getElementById('subtitleToggle');
                    if (subtitleToggle) {
                        if (track.mode === 'showing') {
                            subtitleToggle.style.background = 'rgba(255, 23, 68, 0.3)';
                        } else {
                            subtitleToggle.style.background = 'rgba(255, 255, 255, 0.2)';
                        }
                    }
                }
            }

            function changeSpeed() {
                const speeds = [0.5, 0.75, 1, 1.25, 1.5, 2];
                const currentSpeed = video.playbackRate;
                const currentIndex = speeds.indexOf(currentSpeed);
                const nextIndex = (currentIndex + 1) % speeds.length;

                video.playbackRate = speeds[nextIndex];

                const speedBtn = document.getElementById('speedBtn');
                if (speedBtn) {
                    speedBtn.textContent = speeds[nextIndex] + 'x';
                }
            }

            function toggleFullscreen() {
                if (video) {
                    if (video.requestFullscreen) {
                        video.requestFullscreen();
                    } else if (video.webkitRequestFullscreen) {
                        video.webkitRequestFullscreen();
                    } else if (video.msRequestFullscreen) {
                        video.msRequestFullscreen();
                    }
                }
            }

            function addToFavorites() {
                showNotification('Added to favorites! ❤️', 'success');
            }

            // Video event listeners
            if (video) {
                video.addEventListener('loadedmetadata', function() {
                    updateDuration();
                });

                video.addEventListener('timeupdate', function() {
                    updateProgress();
                    updateCurrentTime();
                });

                video.addEventListener('play', updatePlayButton);
                video.addEventListener('pause', updatePlayButton);
                video.addEventListener('volumechange', updateVolumeButton);

                // Volume slider
                const volumeSlider = document.getElementById('volumeSlider');
                if (volumeSlider) {
                    volumeSlider.addEventListener('input', function() {
                        video.volume = this.value / 100;
                    });
                }

                // Progress bar
                const progressBar = document.querySelector('.progress-bar');
                if (progressBar) {
                    progressBar.addEventListener('click', function(e) {
                        const rect = this.getBoundingClientRect();
                        const clickX = e.clientX - rect.left;
                        const width = rect.width;
                        const percentage = clickX / width;
                        video.currentTime = percentage * video.duration;
                    });
                }
            }

            function updateDuration() {
                const durationElement = document.getElementById('duration');
                if (durationElement && video.duration) {
                    durationElement.textContent = formatTime(video.duration);
                }
            }

            function updateCurrentTime() {
                const currentTimeElement = document.getElementById('currentTime');
                if (currentTimeElement) {
                    currentTimeElement.textContent = formatTime(video.currentTime);
                }
            }

            function updateProgress() {
                const progressFilled = document.getElementById('progressFilled');
                if (progressFilled && video.duration) {
                    const percentage = (video.currentTime / video.duration) * 100;
                    progressFilled.style.width = percentage + '%';
                }
            }

            function formatTime(seconds) {
                const minutes = Math.floor(seconds / 60);
                const remainingSeconds = Math.floor(seconds % 60);
                return `${minutes}:${remainingSeconds.toString().padStart(2, '0')}`;
            }

            // Initialize video controls
            if (video) {
                updatePlayButton();
                updateVolumeButton();
            }

             document.addEventListener('DOMContentLoaded', function() {
            const favoriteBtn = document.getElementById('favoriteBtn');
            
            if (favoriteBtn) {
                favoriteBtn.addEventListener('click', function() {
                    const movieId = this.getAttribute('data-movie-id');
                    const isFavorited = this.classList.contains('favorited');
                    
                    // Disable button during request
                    this.disabled = true;
                    
                    const action = isFavorited ? 'RemoveFromFavorite' : 'AddToFavorite';
                    const antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    
                    fetch(`/Movie/${action}`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': antiForgeryToken
                        },
                        body: `movieId=${movieId}&__RequestVerificationToken=${encodeURIComponent(antiForgeryToken)}`
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            // Toggle button state
                            if (isFavorited) {
                                this.classList.remove('favorited');
                                this.querySelector('i').className = 'far fa-heart';
                                this.querySelector('.favorite-text').textContent = 'Add to Favorites';
                            } else {
                                this.classList.add('favorited');
                                this.querySelector('i').className = 'fas fa-heart';
                                this.querySelector('.favorite-text').textContent = 'Remove from Favorites';
                            }
                            
                            // Show success message (you can customize this)
                            showMessage(data.message, 'success');
                        } else {
                            showMessage(data.message, 'error');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        showMessage('An error occurred. Please try again.', 'error');
                    })
                    .finally(() => {
                        this.disabled = false;
                    });
                });
            }
        });

        function showMessage(message, type) {
            // Create and show a temporary message
            const messageDiv = document.createElement('div');
            messageDiv.textContent = message;
            messageDiv.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                padding: 15px 20px;
                border-radius: 8px;
                color: white;
                font-weight: bold;
                z-index: 1000;
                animation: slideIn 0.3s ease;
                ${type === 'success' ? 'background: #2ed573;' : 'background: #ff3838;'}
            `;
            
            document.body.appendChild(messageDiv);
            
            setTimeout(() => {
                messageDiv.style.animation = 'slideOut 0.3s ease';
                setTimeout(() => {
                    document.body.removeChild(messageDiv);
                }, 300);
            }, 3000);
        }

        // Add CSS animations
        const style = document.createElement('style');
        style.textContent = `
            @@keyframes slideIn {
                from { transform: translateX(100%); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
            @@keyframes slideOut {
                from { transform: translateX(0); opacity: 1; }
                to { transform: translateX(100%); opacity: 0; }
            }
        `;
        document.head.appendChild(style);
</script>
</body>
</html>