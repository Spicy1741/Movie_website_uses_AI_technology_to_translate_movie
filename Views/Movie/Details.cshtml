@model Film_website.Models.Movie
@{
    ViewData["Title"] = Model.Title;
    var comments = ViewBag.Comments as List<Film_website.Models.Comment> ?? new List<Film_website.Models.Comment>();
    var commentCount = ViewBag.CommentCount ?? 0;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Film Website</title>
    <meta name="movie-id" content="@Model.Id" />
    @Html.AntiForgeryToken()
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Bangers&family=Bungee&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>

<body>
    <div class="movie-details-container">
        <!-- Video Section -->
        <section class="video-section">
            <div class="video-container">
                <video id="moviePlayer" controls preload="metadata" data-subtitle-path="@Model.SubtitlePath">
                    @if (!string.IsNullOrEmpty(Model.FilePath))
                    {
                        <source src="@Model.FilePath" type="video/mp4">
                    }
                    @if (!string.IsNullOrEmpty(Model.SubtitlePath))
                    {
                        <track src="@Model.SubtitlePath" kind="subtitles" srclang="en" label="English" id="subtitleTrack">
                    }
                    Your browser does not support the video tag.
                </video>

                @if (string.IsNullOrEmpty(Model.FilePath))
                {
                    <div class="no-video-message">
                        <i class="fas fa-film fa-4x"></i>
                        <h3>🎬 COMING SOON 🎬</h3>
                        <p>This EPIC adventure will be available soon!</p>
                    </div>
                }

                <!-- Video Controls -->
                <div class="custom-controls" id="customControls">
                    <div class="progress-container">
                        <div class="progress-bar" id="progressBar">
                            <div class="progress-filled" id="progressFilled"></div>
                        </div>
                        <div class="time-display">
                            <span id="currentTime">0:00</span> / <span id="duration">0:00</span>
                        </div>
                    </div>
                    
                    <div class="controls-row">
                        <div class="left-controls">
                            <button class="control-btn" onclick="togglePlay()" id="playBtn">
                                <i class="fas fa-play"></i>
                            </button>
                            <button class="control-btn" onclick="skipBackward()">
                                <i class="fas fa-backward"></i> 10s
                            </button>
                            <button class="control-btn" onclick="skipForward()">
                                <i class="fas fa-forward"></i> 10s
                            </button>
                            <div class="volume-control">
                                <button class="control-btn" onclick="toggleMute()" id="volumeBtn">
                                    <i class="fas fa-volume-up"></i>
                                </button>
                                <div class="volume-slider">
                                    <input type="range" min="0" max="100" value="70" id="volumeSlider">
                                </div>
                            </div>
                        </div>

                        <div class="right-controls">
                            @if (!string.IsNullOrEmpty(Model.SubtitlePath))
                            {
                                <button class="control-btn" onclick="toggleSubtitles()" id="subtitleToggle">
                                    <i class="fas fa-closed-captioning"></i>
                                </button>
                            }
                            <button class="control-btn" onclick="changeSpeed()" id="speedBtn">1x</button>
                            <button class="control-btn" onclick="toggleFullscreen()">
                                <i class="fas fa-expand"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Movie Info Section -->
        <section class="movie-info-section">
            <div class="details-header">
                <h1>@Model.Title</h1>
                <div class="movie-meta">
                    <span class="genre-tag">@Model.Genre</span>
                    <span class="year-badge">@Model.ReleaseYear</span>
                    <span class="rating-badge">⭐ EPIC</span>
                </div>
            </div>

            <div class="movie-metadata">
                <div class="metadata-grid">
                    <div class="metadata-item">
                        <div class="metadata-label">Genre:</div>
                        <div class="metadata-value">
                            <span class="genre-tag">@Model.Genre</span>
                        </div>
                    </div>
                    
                    <div class="metadata-item">
                        <div class="metadata-label">Release Year:</div>
                        <div class="metadata-value">@Model.ReleaseYear</div>
                    </div>
                    
                    <div class="metadata-item">
                        <div class="metadata-label">Added:</div>
                        <div class="metadata-value">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                    </div>
                    
                    <div class="metadata-item">
                        <div class="metadata-label">Subtitles:</div>
                        <div class="metadata-value">
                            @if (!string.IsNullOrEmpty(Model.SubtitlePath))
                            {
                                <span class="subtitle-available">
                                    <i class="fas fa-check"></i> Available
                                </span>
                            }
                            else
                            {
                                <span class="subtitle-unavailable">
                                    <i class="fas fa-times"></i> Not Available
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="movie-description">
                <h3><i class="fas fa-film"></i> Description</h3>
                <p>@Model.Description</p>
            </div>

            <div class="movie-actions">
                <button class="action-btn primary" onclick="playMovie()">
                    <i class="fas fa-play"></i> WATCH NOW
                </button>
                @if (!string.IsNullOrEmpty(Model.SubtitlePath))
                {
                    <button class="action-btn subtitle" onclick="toggleSubtitles()">
                        <i class="fas fa-closed-captioning"></i> TOGGLE SUBTITLES
                    </button>
                }
                <button class="action-btn secondary" onclick="addToFavorites()">
                    <i class="fas fa-heart"></i> ADD TO FAVORITES
                </button>
                <a href="@Url.Action("Index", "Movie")" class="action-btn">
                    <i class="fas fa-arrow-left"></i> BACK TO MOVIES
                </a>
            </div>
        </section>

        <!-- Comments Section -->
        <section class="comments-section-details" data-movie-id="@Model.Id">
            <div class="comments-container">
                <h3>💬 HERO REVIEWS 💬 <span class="comment-count">(@commentCount)</span></h3>

                @if (User.Identity.IsAuthenticated)
                {
                    <!-- Comment Form -->
                    <div class="comment-form">
                        <div class="comment-input-container">
                            <div class="user-avatar">
                                @{
                                    var userInitials = "U";
                                    var userService = Context.RequestServices.GetService(typeof(Film_website.Services.UserService)) as Film_website.Services.UserService;
                                    if (userService != null && User.Identity.Name != null)
                                    {
                                        var currentUser = await userService.GetUserByEmailOrUserNameAsync(User.Identity.Name);
                                        if (currentUser != null)
                                        {
                                            userInitials = "";
                                            if (!string.IsNullOrEmpty(currentUser.FirstName))
                                                userInitials += currentUser.FirstName[0].ToString().ToUpper();
                                            if (!string.IsNullOrEmpty(currentUser.LastName))
                                                userInitials += currentUser.LastName[0].ToString().ToUpper();
                                            if (string.IsNullOrEmpty(userInitials))
                                                userInitials = "U";
                                        }
                                    }
                                }
                                @userInitials
                            </div>
                            <textarea placeholder="Share your EPIC thoughts about this LEGENDARY movie..." 
                                      id="newComment" 
                                      class="comment-textarea"
                                      rows="3" 
                                      maxlength="1000"></textarea>
                        </div>
                        <div class="comment-actions">
                            <button class="action-btn secondary" onclick="cancelComment()">❌ CANCEL</button>
                            <button class="action-btn primary" onclick="addComment()">💥 POST REVIEW</button>
                        </div>
                        <div class="comment-help-text">
                            <small>Share your thoughts! Maximum 1000 characters.</small>
                        </div>
                    </div>
                }
                else
                {
                    <!-- Login Prompt -->
                    <div class="login-prompt">
                        <p>🦸 <a href="@Url.Action("Login", "Account")">Login</a> or <a href="@Url.Action("Register", "Account")">Register</a> to share your EPIC thoughts! 🦸</p>
                    </div>
                }

                <!-- Comments List -->
                <div class="comments-list" id="commentsList">
                    @if (comments.Any())
                    {
                        @foreach (var comment in comments)
                        {
                            var userCommentInitials = "U";
                            if (!string.IsNullOrEmpty(comment.User.FirstName))
                                userCommentInitials = comment.User.FirstName[0].ToString().ToUpper();
                            if (!string.IsNullOrEmpty(comment.User.LastName))
                                userCommentInitials += comment.User.LastName[0].ToString().ToUpper();
                            if (userCommentInitials == "U" && !string.IsNullOrEmpty(comment.User.LastName))
                                userCommentInitials = comment.User.LastName[0].ToString().ToUpper();

                            var timeAgo = GetTimeAgo(comment.CreatedAt);
                            var editedText = comment.IsEdited ? " (edited)" : "";
                            var canEdit = User.Identity.IsAuthenticated && User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value == comment.UserId;
                            var canDelete = canEdit || User.IsInRole("Admin");

                            <div class="comment-item" data-comment-id="@comment.Id">
                                <div class="comment-header">
                                    <div class="comment-avatar">@userCommentInitials</div>
                                    <div class="comment-info">
                                        <div class="comment-author">@comment.User.DisplayUserName</div>
                                        <div class="comment-time">@timeAgo@editedText</div>
                                    </div>
                                    @if (canEdit || canDelete)
                                    {
                                        <div class="comment-options">
                                            <button class="comment-option-btn" onclick="toggleCommentOptions(@comment.Id)">⋮</button>
                                            <div class="comment-options-menu" id="options-@comment.Id" style="display: none;">
                                                @if (canEdit)
                                                {
                                                    <button onclick="editComment(@comment.Id)">Edit</button>
                                                }
                                                @if (canDelete)
                                                {
                                                    <button onclick="deleteComment(@comment.Id)" class="delete-option">Delete</button>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="comment-content" id="content-@comment.Id">
                                    @comment.Content
                                </div>
                                <div class="comment-actions-inline">
                                    <button class="comment-action-btn" onclick="likeComment(@comment.Id)" id="like-btn-@comment.Id">
                                        👍 <span id="like-count-@comment.Id">@comment.LikeCount</span>
                                    </button>
                                    <button class="comment-action-btn" onclick="replyComment(@comment.Id)">↩ Reply</button>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="no-comments-message">
                            <p>🎬 Be the first to share your EPIC thoughts about this movie! 🎬</p>
                        </div>
                    }
                </div>

                <!-- Load More Comments -->
                <div class="load-more-container">
                    <button class="action-btn secondary load-more-btn" onclick="loadMoreComments()" style="display: @(comments.Count >= 10 ? "block" : "none")">⚡ LOAD MORE HERO REVIEWS ⚡</button>
                </div>
            </div>
        </section>
    </div>

    <!-- Scripts -->
    <script src="~/js/movie-comments.js"></script>

    <style>
        /* Root Variables */
        :root {
            --primary-red: #ff1744;
            --dark-red: #d50000;
            --light-black: #1a1a1a;
            --medium-gray: #2d2d2d;
            --light-gray: #404040;
            --text-gray: #b0b0b0;
            --white: #ffffff;
            --success-green: #4caf50;
            --warning-orange: #ff9800;
            --error-red: #f44336;
        }

        /* Base Styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 50%, #0f0f0f 100%);
            color: var(--white);
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Movie Details Container */
        .movie-details-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }

        /* Video Section */
        .video-section {
            margin-bottom: 3rem;
        }

        .video-container {
            position: relative;
            background: #000;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        #moviePlayer {
            width: 100%;
            height: auto;
            min-height: 400px;
            display: block;
        }

        .no-video-message {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 400px;
            background: var(--medium-gray);
            color: var(--text-gray);
            text-align: center;
            padding: 3rem;
            border: 2px dashed rgba(255, 255, 255, 0.2);
            border-radius: 15px;
        }

        .no-video-message i {
            color: rgba(255, 255, 255, 0.3);
            margin-bottom: 1rem;
        }

        .no-video-message h3 {
            margin: 1rem 0;
            color: rgba(255, 255, 255, 0.7);
            font-family: 'Bangers', cursive;
            font-size: 2rem;
            letter-spacing: 2px;
        }

        /* Custom Video Controls */
        .custom-controls {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
            padding: 1rem;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .video-container:hover .custom-controls {
            opacity: 1;
        }

        .progress-container {
            margin-bottom: 1rem;
        }

        .progress-bar {
            width: 100%;
            height: 6px;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 3px;
            cursor: pointer;
            margin-bottom: 0.5rem;
        }

        .progress-filled {
            height: 100%;
            background: var(--primary-red);
            border-radius: 3px;
            width: 0%;
            transition: width 0.1s ease;
        }

        .time-display {
            color: white;
            font-size: 0.9rem;
            text-align: center;
        }

        .controls-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .left-controls, .right-controls {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .control-btn {
            background: rgba(255, 255, 255, 0.2);
            border: none;
            color: white;
            padding: 0.5rem;
            border-radius: 5px;
            cursor: pointer;
            transition: background 0.3s ease;
            font-size: 0.9rem;
        }

        .control-btn:hover {
            background: rgba(255, 255, 255, 0.4);
        }

        .volume-control {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .volume-slider input {
            width: 80px;
        }

        /* Movie Info Section */
        .movie-info-section {
            margin-bottom: 3rem;
        }

        .details-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .details-header h1 {
            font-family: 'Bangers', cursive;
            font-size: 3rem;
            color: var(--primary-red);
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
            margin-bottom: 1rem;
            letter-spacing: 2px;
        }

        .movie-meta {
            display: flex;
            justify-content: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .genre-tag, .year-badge, .rating-badge {
            background: linear-gradient(45deg, var(--primary-red), var(--dark-red));
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-weight: bold;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .movie-metadata {
            background: rgba(255, 255, 255, 0.05);
            padding: 2rem;
            border-radius: 15px;
            margin-bottom: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .metadata-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .metadata-item {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .metadata-label {
            font-size: 0.9rem;
            color: var(--text-gray);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .metadata-value {
            font-size: 1.1rem;
            font-weight: 600;
        }

        .subtitle-available {
            color: var(--success-green);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .subtitle-unavailable {
            color: var(--error-red);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .movie-description {
            background: rgba(255, 255, 255, 0.05);
            padding: 2rem;
            border-radius: 15px;
            margin-bottom: 2rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .movie-description h3 {
            margin-bottom: 1rem;
            color: var(--primary-red);
            font-size: 1.5rem;
            font-family: 'Bungee', cursive;
        }

        .movie-description p {
            line-height: 1.8;
            font-size: 1.1rem;
        }

        /* Action Buttons */
        .movie-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-bottom: 3rem;
        }

        .action-btn {
            background: linear-gradient(45deg, var(--medium-gray), var(--light-gray));
            border: 2px solid rgba(255, 255, 255, 0.1);
            color: white;
            padding: 1rem 2rem;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1rem;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .action-btn.primary {
            background: linear-gradient(45deg, var(--primary-red), var(--dark-red));
            border-color: var(--primary-red);
        }

        .action-btn.secondary {
            background: linear-gradient(45deg, var(--medium-gray), var(--light-gray));
            border-color: var(--light-gray);
        }

        .action-btn.subtitle {
            background: linear-gradient(45deg, #9c27b0, #7b1fa2);
            border-color: #9c27b0;
        }

        .action-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(255, 23, 68, 0.3);
        }

        .action-btn.primary:hover {
            background: linear-gradient(45deg, #ff5983, var(--primary-red));
            box-shadow: 0 8px 25px rgba(255, 23, 68, 0.5);
        }

        .action-btn.subtitle:hover {
            background: linear-gradient(45deg, #ba68c8, #9c27b0);
            box-shadow: 0 8px 25px rgba(156, 39, 176, 0.4);
        }

        /* Comments Section */
        .comments-section-details {
            background: rgba(0, 0, 0, 0.7);
            border-radius: 20px;
            padding: 2rem;
            margin-top: 3rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .comments-container h3 {
            color: var(--primary-red);
            font-size: 1.8rem;
            margin-bottom: 2rem;
            text-align: center;
            font-family: 'Bangers', cursive;
            letter-spacing: 2px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
        }

        .comment-count {
            color: rgba(255, 255, 255, 0.8);
            font-size: 1.2rem;
        }

        /* Comment Form */
        .comment-form {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            border: 2px solid rgba(255, 23, 68, 0.3);
            transition: all 0.3s ease;
        }

        .comment-form:hover {
            border-color: rgba(255, 23, 68, 0.5);
            background: rgba(255, 255, 255, 0.08);
        }

        .comment-input-container {
            display: flex;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .user-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(45deg, var(--primary-red), #ff5722);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
            font-size: 14px;
            flex-shrink: 0;
            box-shadow: 0 4px 10px rgba(255, 23, 68, 0.3);
        }

        .comment-textarea {
            flex: 1;
            background: rgba(0, 0, 0, 0.3);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            padding: 1rem;
            color: white;
            font-family: inherit;
            font-size: 14px;
            resize: vertical;
            min-height: 80px;
            transition: all 0.3s ease;
        }

        .comment-textarea:focus {
            outline: none;
            border-color: var(--primary-red);
            box-shadow: 0 0 10px rgba(255, 23, 68, 0.3);
            background: rgba(0, 0, 0, 0.5);
        }

        .comment-textarea::placeholder {
            color: rgba(255, 255, 255, 0.6);
        }

        .comment-actions {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
        }

        .comment-help-text {
            margin-top: 0.5rem;
            text-align: right;
        }

        .comment-help-text small {
            color: rgba(255, 255, 255, 0.6);
            font-size: 12px;
        }

        /* Login Prompt */
        .login-prompt {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            padding: 2rem;
            text-align: center;
            margin-bottom: 2rem;
            border: 2px solid rgba(255, 23, 68, 0.3);
        }

        .login-prompt p {
            color: white;
            font-size: 16px;
            margin: 0;
        }

        .login-prompt a {
            color: var(--primary-red);
            text-decoration: none;
            font-weight: bold;
            transition: color 0.3s ease;
        }

        .login-prompt a:hover {
            color: #ff5722;
            text-decoration: underline;
        }

        /* Comment Items */
        .comment-item {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }

        .comment-item:hover {
            background: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 23, 68, 0.3);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
        }

        .comment-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
            position: relative;
        }

        .comment-avatar {
            width: 40px;
            height: 40px;
            background: linear-gradient(45deg, var(--primary-red), #ff5722);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: white;
            font-size: 14px;
            flex-shrink: 0;
        }

        .comment-info {
            flex: 1;
        }

        .comment-author {
            color: var(--primary-red);
            font-weight: bold;
            font-size: 14px;
            margin-bottom: 2px;
        }

        .comment-time {
            color: rgba(255, 255, 255, 0.6);
            font-size: 12px;
        }

        .comment-content {
            color: white;
            line-height: 1.6;
            margin-bottom: 1rem;
            word-wrap: break-word;
        }

        /* Comment Options */
        .comment-options {
            position: relative;
        }

        .comment-option-btn {
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.6);
            cursor: pointer;
            padding: 5px;
            border-radius: 5px;
            transition: all 0.3s ease;
        }

        .comment-option-btn:hover {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .comment-options-menu {
            position: absolute;
            top: 100%;
            right: 0;
            background: rgba(0, 0, 0, 0.9);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            padding: 0.5rem 0;
            min-width: 120px;
            z-index: 10;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        }

        .comment-options-menu button {
            display: block;
            width: 100%;
            background: none;
            border: none;
            color: white;
            padding: 0.5rem 1rem;
            text-align: left;
            cursor: pointer;
            transition: background 0.3s ease;
        }

        .comment-options-menu button:hover {
            background: rgba(255, 255, 255, 0.1);
        }

        .comment-options-menu button.delete-option {
            color: #ff4444;
        }

        .comment-options-menu button.delete-option:hover {
            background: rgba(255, 68, 68, 0.2);
        }

        /* Comment Actions */
        .comment-actions-inline {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .comment-action-btn {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .comment-action-btn:hover {
            background: rgba(255, 255, 255, 0.2);
            border-color: rgba(255, 255, 255, 0.4);
            transform: translateY(-1px);
        }

        .comment-action-btn.liked {
            background: rgba(255, 23, 68, 0.3);
            border-color: var(--primary-red);
            color: var(--primary-red);
        }

        /* Edit Comment */
        .edit-comment-textarea {
            width: 100%;
            background: rgba(0, 0, 0, 0.3);
            border: 2px solid rgba(255, 255, 255, 0.1);
            border-radius: 8px;
            padding: 1rem;
            color: white;
            font-family: inherit;
            font-size: 14px;
            resize: vertical;
            min-height: 80px;
            margin-bottom: 1rem;
        }

        .edit-comment-textarea:focus {
            outline: none;
            border-color: var(--primary-red);
            box-shadow: 0 0 10px rgba(255, 23, 68, 0.3);
        }

        .edit-comment-actions {
            display: flex;
            gap: 0.5rem;
            justify-content: flex-end;
        }

        .btn-small {
            padding: 0.5rem 1rem;
            font-size: 12px;
            border-radius: 8px;
        }

        /* No Comments Message */
        .no-comments-message {
            text-align: center;
            padding: 3rem 1rem;
            color: rgba(255, 255, 255, 0.6);
            font-style: italic;
        }

        /* Loading States */
        .comments-loading {
            text-align: center;
            padding: 2rem;
            color: rgba(255, 255, 255, 0.6);
            font-style: italic;
        }

        /* Load More Button */
        .load-more-container {
            text-align: center;
            margin-top: 2rem;
        }

        .load-more-btn {
            background: linear-gradient(45deg, var(--medium-gray), var(--light-gray));
        }

        /* Notifications */
        .notification {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 1rem 1.5rem;
            border-radius: 8px;
            color: white;
            font-weight: bold;
            z-index: 1000;
            max-width: 400px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            animation: slideInFromRight 0.3s ease-out;
        }

        .notification-success {
            background: rgba(34, 197, 94, 0.9);
            border: 1px solid #22c55e;
        }

        .notification-error {
            background: rgba(220, 38, 38, 0.9);
            border: 1px solid #dc2626;
        }

        .notification-warning {
            background: rgba(245, 158, 11, 0.9);
            border: 1px solid #f59e0b;
        }

        .notification-info {
            background: rgba(59, 130, 246, 0.9);
            border: 1px solid #3b82f6;
        }

        .notification button {
            background: none;
            border: none;
            color: white;
            cursor: pointer;
            font-size: 18px;
            padding: 0;
            line-height: 1;
        }

        @@keyframes slideInFromRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        /* Responsive Design */
        @@media (max-width: 768px) {
            .movie-details-container {
                padding: 1rem;
            }

            .details-header h1 {
                font-size: 2rem;
            }

            .movie-meta {
                justify-content: center;
            }

            .metadata-grid {
                grid-template-columns: 1fr;
            }

            .movie-actions {
                flex-direction: column;
                align-items: center;
            }

            .action-btn {
                min-width: 200px;
                justify-content: center;
            }

            .comment-input-container {
                flex-direction: column;
                gap: 0.5rem;
            }

            .comment-actions {
                justify-content: center;
            }

            .comments-section-details {
                padding: 1rem;
            }

            .comment-item {
                padding: 1rem;
            }

            .controls-row {
                flex-direction: column;
                gap: 1rem;
            }

            .left-controls, .right-controls {
                justify-content: center;
            }
        }

        @@media (max-width: 480px) {
            .details-header h1 {
                font-size: 1.5rem;
            }

            .movie-meta {
                flex-direction: column;
                align-items: center;
            }

            .comment-form {
                padding: 1rem;
            }

            .comment-textarea {
                min-height: 60px;
            }

            .user-avatar, .comment-avatar {
                width: 32px;
                height: 32px;
                font-size: 12px;
            }
        }
    </style>

