@model List<Film_website.Models.Movie>
@{
    ViewData["Title"] = "Search Movies";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var searchQuery = ViewBag.SearchQuery as string ?? "";
    var resultCount = ViewBag.ResultCount as int? ?? 0;
}

<div class="search-page-container">
    <div class="container-fluid">

        <!-- Search Header -->
        <div class="search-header">
            <h1>🔍 Search Movies</h1>
            <p>Find your favorite movies from our collection</p>
        </div>

        <!-- Search Form -->
        <div class="search-form-container">
            <form method="get" asp-action="Search" asp-controller="Movie" id="searchForm">
                <div class="search-input-group">
                    <i class="fas fa-search search-icon-large"></i>
                    <input type="text"
                           name="query"
                           value="@searchQuery"
                           placeholder="Enter movie title, genre, or description..."
                           class="search-input-large"
                           id="searchInput"
                           autocomplete="off">
                </div>
                <button type="submit" class="search-button">
                    <i class="fas fa-search"></i> Search Movies
                </button>
            </form>
        </div>

        <!-- Search Results -->
        <div class="search-results-container">
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                if (resultCount > 0)
                {
                    <!-- Results Header -->
                    <div class="search-results-header">
                        <h2>Search Results</h2>
                        <p class="search-results-count">
                            Found @resultCount movie@(resultCount != 1 ? "s" : "") for "@searchQuery"
                        </p>
                    </div>

                    <!-- Movie Grid -->
                    <div class="search-movie-grid">
                        @foreach (var movie in Model)
                        {
                            <div class="search-movie-card" data-movie-id="@movie.Id">
                                <div class="search-movie-poster">
                                    @if (!string.IsNullOrEmpty(movie.ThumbnailPath))
                                    {
                                        <img src="@movie.ThumbnailPath" alt="@movie.Title" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="no-poster-placeholder">
                                            <i class="fas fa-film"></i>
                                            <span>No Image</span>
                                        </div>
                                    }

                                    <!-- Overlay with movie info -->
                                    <div class="movie-overlay">
                                        <div class="movie-overlay-content">
                                            <h4>@movie.Title</h4>
                                            <p>@movie.Genre</p>
                                            <p>@movie.ReleaseYear</p>
                                            <a href="@Url.Action("Details", "Movie", new { id = movie.Id })" class="watch-btn">
                                                <i class="fas fa-play"></i> View Details
                                            </a>
                                        </div>
                                    </div>
                                </div>

                                <div class="search-movie-info">
                                    <h4>@movie.Title</h4>
                                    <p>@movie.Genre • @movie.ReleaseYear</p>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <!-- No Results Found -->
                    <div class="no-results">
                        <div class="no-results-icon">
                            <i class="fas fa-search"></i>
                        </div>
                        <h3>Movie not found</h3>
                        <p>No movies found for "@searchQuery". Try searching with different keywords.</p>
                    </div>
                }
            }
            else
            {
                <!-- Initial state - no search performed -->
                <div class="no-results">
                    <div class="no-results-icon">
                        <i class="fas fa-film"></i>
                    </div>
                    <h3>Start Your Search</h3>
                    <p>Enter a movie title, genre, or description to find movies in our collection.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- JavaScript for enhanced search functionality -->
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchForm = document.getElementById('searchForm');
        const searchInput = document.getElementById('searchInput');

        // Focus on search input when page loads
        if (searchInput) {
            searchInput.focus();
        }

        // Handle Enter key press
        searchInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                searchForm.submit();
            }
        });

        // Add loading state when form is submitted
        searchForm.addEventListener('submit', function() {
            const button = searchForm.querySelector('button[type="submit"]');
            const originalText = button.innerHTML;
            button.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Searching...';
            button.disabled = true;

            // Re-enable button after a short delay (in case of quick response)
            setTimeout(() => {
                button.innerHTML = originalText;
                button.disabled = false;
            }, 2000);
        });
    });
</script>