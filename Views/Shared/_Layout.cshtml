@using Microsoft.AspNetCore.Identity
@inject UserManager<Film_website.Models.User> UserManager
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Film Website</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Header với navigation -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark">
            <div class="container">
                <!-- Logo with better proportions -->
                <a class="navbar-brand hover-scale slide-in-left" asp-controller="" asp-action="">
                    <i class="fas fa-film"></i>Film Website
                </a>

                <!-- Mobile toggle button -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <!-- Left navigation with improved spacing -->
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home"></i>Hompage
                            </a>
                        </li>
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Favorites", "Movie")">
                                    <i class="fas fa-heart"></i> My Favorites
                                </a>
                            </li>
                        }
                    </ul>

                    <!-- Search bar with improved proportions -->
                    @if (User.Identity!.IsAuthenticated)
                    {
                        <div class="search-icon-container">
                            <a href="@Url.Action("Search", "Movie")" class="search-icon-link" title="Search Movies">
                                <i class="fas fa-search"></i>
                            </a>
                        </div>
                    }

                    <!-- Right side authentication with better ratios -->
                    <div class="navbar-nav">
                        @if (User.Identity!.IsAuthenticated)
                        {
                            <!-- User dropdown with improved structure -->
                            <div class="dropdown">
                                <button class="dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <div class="user-avatar-container">
                                        @{
                                            var currentUser = await UserManager.GetUserAsync(User);
                                            var avatarPath = currentUser?.AvatarPath;
                                        }
                                        @if (!string.IsNullOrEmpty(avatarPath))
                                        {
                                            <img src="@avatarPath" alt="Avatar" class="navbar-avatar-image" />
                                        }
                                        else
                                        {
                                            @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                        }
                                    </div>
                                    <div class="user-info d-none d-md-flex">
                                        <span class="user-name">@(User.Identity.Name ?? "User")</span>
                                        <span class="user-role">
                                            @if (User.IsInRole("Admin"))
                                            {
                                                <span class="badge bg-warning text-dark">Admin</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">User</span>
                                            }
                                        </span>
                                    </div>
                                </button>

                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li class="dropdown-header">
                                        <div class="d-flex align-items-center">
                                            <div class="user-avatar-container me-3">
                                                @if (!string.IsNullOrEmpty(avatarPath))
                                                {
                                                    <img src="@avatarPath" alt="Avatar" class="navbar-avatar-image" />
                                                }
                                                else
                                                {
                                                    @(User.Identity.Name?.Substring(0, 1).ToUpper() ?? "U")
                                                }
                                            </div>
                                            <div>
                                                <div class="fw-semibold">@User.Identity.Name</div>
                                                <div class="small text-muted">Your account</div>
                                            </div>
                                        </div>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="fas fa-user-circle"></i>
                                            Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="EditProfile">
                                            <i class="fas fa-edit"></i>
                                            Edit profile
                                        </a>
                                    </li>
                                   
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="index">
                                                <i class="fas fa-cogs"></i>
                                                Admin
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="dropdown-item">
                                                <i class="fas fa-sign-out-alt"></i>
                                                Log out
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <!-- Authentication buttons with improved proportions -->
                            <div class="auth-buttons slide-in-right">
                                <a class="btn-login" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt"></i>
                                    Login
                                </a>
                                <a class="btn-register" asp-controller="Account" asp-action="Register">
                                    <i class="fas fa-user-plus"></i>
                                    Register
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- Main Content Area -->
    <main>
        <div class="container-fluid">
            <!-- Alert Messages -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show fade-in-up" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show fade-in-up" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Page Content -->
            @RenderBody()
        </div>
    </main>

    <!-- Floating Logout Button (Mobile - chỉ hiện khi đã đăng nhập) -->
    @if (User.Identity!.IsAuthenticated)
    {
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="floating-logout d-md-none" onclick="return confirmLogout()" title="Đăng xuất">
                <i class="fas fa-sign-out-alt"></i>
            </button>
        </form>
    }

    <!-- Replace your footer section in _Layout.cshtml with this corrected structure -->

    <footer class="enhanced-footer">
        <div class="footer-content">
            <div class="container">
                <div class="row">
                    <!-- Brand Section - 3 columns on large screens -->
                    <div class="col-lg-3 col-md-6 col-12 mb-4">
                        <div class="footer-brand">
                            <h3>
                                <i class="fas fa-film"></i>
                                Film Website
                            </h3>
                            <p>Your ultimate destination for discovering, watching, and enjoying the best movies and TV series from around the world.</p>
                            <div class="social-links">
                                <a href="#" title="Facebook" aria-label="Follow us on Facebook">
                                    <i class="fab fa-facebook-f"></i>
                                </a>
                                <a href="#" title="Twitter" aria-label="Follow us on Twitter">
                                    <i class="fab fa-twitter"></i>
                                </a>
                                <a href="#" title="Instagram" aria-label="Follow us on Instagram">
                                    <i class="fab fa-instagram"></i>
                                </a>
                                <a href="#" title="YouTube" aria-label="Subscribe to our YouTube channel">
                                    <i class="fab fa-youtube"></i>
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Browse Section - 2 columns on large screens -->
                    <div class="col-lg-2 col-md-6 col-6 mb-4">
                        <div class="footer-section">
                            <h5>Browse</h5>
                            <ul class="footer-links">
                                <li><a asp-controller="Home" asp-action="Index"><i class="fas fa-home"></i> Home</a></li>
                                <li><a asp-controller="Movie" asp-action="Index"><i class="fas fa-video"></i> Movies</a></li>
                                <li><a asp-controller="Movie" asp-action="Categories"><i class="fas fa-tags"></i> Categories</a></li>
                                <li><a asp-controller="Movie" asp-action="Favorites"><i class="fas fa-heart"></i> My Favorites</a></li>
                                <li><a asp-controller="Movie" asp-action="Search"><i class="fas fa-search"></i> Search</a></li>
                            </ul>
                        </div>
                    </div>

                    <!-- Genres Section - 2 columns on large screens -->
                    <div class="col-lg-2 col-md-6 col-6 mb-4">
                        <div class="footer-section">
                            <h5>Genres</h5>
                            <ul class="footer-links">
                                <li><a href="#"><i class="fas fa-magic"></i> Action</a></li>
                                <li><a href="#"><i class="fas fa-laugh"></i> Comedy</a></li>
                                <li><a href="#"><i class="fas fa-heart-broken"></i> Drama</a></li>
                                <li><a href="#"><i class="fas fa-ghost"></i> Horror</a></li>
                                <li><a href="#"><i class="fas fa-rocket"></i> Sci-Fi</a></li>
                            </ul>
                        </div>
                    </div>

                    <!-- Account Section - 2 columns on large screens -->
                    <div class="col-lg-2 col-md-6 col-6 mb-4">
                        <div class="footer-section">
                            <h5>Account</h5>
                            <ul class="footer-links">
                                @if (User.Identity!.IsAuthenticated)
                                {
                                    <li><a asp-controller="Account" asp-action="Profile"><i class="fas fa-user"></i> My Profile</a></li>
                                    <li><a asp-controller="Account" asp-action="EditProfile"><i class="fas fa-edit"></i> Edit Profile</a></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit" class="footer-link-btn"><i class="fas fa-sign-out-alt"></i> Logout</button>
                                        </form>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a asp-controller="Admin" asp-action="Index"><i class="fas fa-cogs"></i> Admin Panel</a></li>
                                    }
                                }
                                else
                                {
                                    <li><a asp-controller="Account" asp-action="Login"><i class="fas fa-sign-in-alt"></i> Login</a></li>
                                    <li><a asp-controller="Account" asp-action="Register"><i class="fas fa-user-plus"></i> Register</a></li>
                                }
                            </ul>
                        </div>
                    </div>

                    <!-- Support Section - 3 columns on large screens -->
                    <div class="col-lg-3 col-md-6 col-12 mb-4">
                        <div class="footer-section">
                            <h5>Support</h5>
                            <ul class="footer-links">
                                <li><a href="#"><i class="fas fa-question-circle"></i> Help Center</a></li>
                                <li><a href="#"><i class="fas fa-envelope"></i> Contact Us</a></li>
                                <li><a href="#"><i class="fas fa-comments"></i> Community</a></li>
                                <li><a href="#"><i class="fas fa-bug"></i> Report Issue</a></li>
                                <li><a href="#"><i class="fas fa-star"></i> Rate Us</a></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Footer Bottom Section -->
                <div class="footer-bottom">
                    <div class="row align-items-center">
                        <div class="col-md-8 col-12">
                            <div class="footer-legal">
                                <a href="#">Privacy Policy</a>
                                <a href="#">Terms & Conditions</a>
                                <a href="#">Code of Conduct</a>
                                <a href="#">Cookie Policy</a>
                                <a href="#">DMCA</a>
                            </div>
                        </div>
                        <div class="col-md-4 col-12">
                            <p class="copyright">&copy; 2025 Film Website. All rights reserved.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        // Logout confirmation
        function confirmLogout() {
            return Swal.fire({
                title: 'Xác nhận đăng xuất',
                text: 'Bạn có chắc chắn muốn đăng xuất không?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#e50914',
                cancelButtonColor: '#6c757d',
                confirmButtonText: '<i class="fas fa-sign-out-alt me-1"></i>Đăng xuất',
                cancelButtonText: '<i class="fas fa-times me-1"></i>Hủy',
                reverseButtons: true,
                background: '#2c2c2c',
                color: '#fff'
            }).then((result) => {
                return result.isConfirmed;
            });
        }

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const navbar = document.querySelector('.navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });

        // Auto-close mobile menu when clicking outside
        document.addEventListener('click', (e) => {
            const navbarCollapse = document.querySelector('.navbar-collapse');
            const navbarToggler = document.querySelector('.navbar-toggler');

            if (navbarCollapse && navbarCollapse.classList.contains('show') &&
                !navbarCollapse.contains(e.target) &&
                !navbarToggler.contains(e.target)) {
                navbarToggler.click();
            }
        });

        // Search functionality
        const searchForm = document.querySelector('form[role="search"]');
        if (searchForm) {
            searchForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const query = e.target.querySelector('input').value.trim();
                if (query) {
                    console.log('Searching for:', query);
                    // Implement search functionality here
                    Swal.fire({
                        title: 'Tìm kiếm',
                        text: `Đang tìm kiếm: "${query}"`,
                        icon: 'info',
                        timer: 2000,
                        showConfirmButton: false,
                        background: '#2c2c2c',
                        color: '#fff'
                    });
                }
            });
        }

        // Auto-hide alerts after 5 seconds
        setTimeout(() => {
            const alerts = document.querySelectorAll('.alert-success');
            alerts.forEach(alert => {
                setTimeout(() => {
                    alert.style.opacity = '0';
                    setTimeout(() => alert.remove(), 300);
                }, 5000);
            });
        }, 100);

        // Add smooth animations on page load
        window.addEventListener('load', () => {
            document.body.style.opacity = '0';
            document.body.style.transition = 'opacity 0.5s ease-in-out';

            setTimeout(() => {
                document.body.style.opacity = '1';
            }, 100);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>